+// clearcote: look up the persona MediaCapabilities triple for a video codec.
+// Returns false for unmapped/unknown codecs so the real (host) value is kept --
+// only the five spoofed families are overridden, never over-claiming obscure
+// codecs (VC1/MPEG2/Theora/...).
+bool CcPersonaCodec(media::VideoCodec c,
+                    ungoogled::PersonaProfile::MediaCodecSupport* out) {
+  const char* key = nullptr;
+  switch (c) {
+    case media::VideoCodec::kH264: key = "h264"; break;
+    case media::VideoCodec::kVP8: key = "vp8"; break;
+    case media::VideoCodec::kVP9: key = "vp9"; break;
+    case media::VideoCodec::kAV1: key = "av1"; break;
+    case media::VideoCodec::kHEVC: key = "hevc"; break;
+    default: return false;
+  }
+  const auto& m = ungoogled::CurrentPersona().media_codecs;
+  auto it = m.find(key);
+  if (it == m.end()) return false;
+  *out = it->second;
+  return true;
+}
