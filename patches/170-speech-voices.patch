+// clearcote: Windows SAPI5 voice packs keyed by BCP-47 tag. These are the real
+// "Microsoft <Name> - <Language> (<Country>)" strings Chrome-on-Windows reports
+// once the matching Windows display-language pack is installed; the first entry
+// of a row is that locale's SAPI default voice. Only locales whose voice names
+// are known are listed -- an unlisted tag falls through to the en-US base set,
+// which is what a Windows install with no matching pack actually reports.
+struct LocaleVoiceRow {
+  const char* tag;       // lowercase BCP-47; full-tag match wins, else language
+  const char* lang;      // the lang string these voices report
+  const char* names[3];  // unused slots are nullptr
+};
