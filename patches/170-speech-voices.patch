+// The exact set DerivePersona() installs as the Windows default. Anything else
+// in PersonaProfile::voices came from an imported profile (a real capture) and
+// must not be rewritten.
+bool IsBuiltinWindowsDefaultVoiceSet(
+    const std::vector<PersonaProfile::Voice>& v) {
+  return v.size() == 3 &&
+         v[0].name == "Microsoft David - English (United States)" &&
+         v[1].name == "Microsoft Zira - English (United States)" &&
+         v[2].name == "Microsoft Mark - English (United States)";
+}
+
+// First token of an Accept-Language list, normalized the way
+// NavigatorLanguage::ParseAndSanitize() normalizes navigator.languages[0]
+// (trimmed, '_' -> '-'), then lowercased for table lookup and stripped of any
+// ";q=" weight.
+std::string PrimaryLanguageTag(const std::string& accept_languages) {
+  std::string tag = accept_languages.substr(0, accept_languages.find(','));
+  const size_t q = tag.find(';');
+  if (q != std::string::npos)
+    tag = tag.substr(0, q);
+  const size_t b = tag.find_first_not_of(" \t");
+  if (b == std::string::npos)
+    return std::string();
+  tag = tag.substr(b, tag.find_last_not_of(" \t") - b + 1);
+  for (char& c : tag) {
+    if (c == '_')
+      c = '-';
+    else if (c >= 'A' && c <= 'Z')
+      c = static_cast<char>(c - 'A' + 'a');
+  }
+  return tag;
+}
+
+const LocaleVoiceRow* FindLocaleVoiceRow(const std::string& tag) {
+  if (tag.empty())
+    return nullptr;
+  for (const LocaleVoiceRow& row : kLocaleVoices) {
+    if (tag == row.tag)
+      return &row;
+  }
+  // No region match ("de", or an unlisted region like "de-AT"): fall back to
+  // the first row for that language subtag, which is the pack Windows installs.
+  const std::string lang = tag.substr(0, tag.find('-'));
+  for (const LocaleVoiceRow& row : kLocaleVoices) {
+    if (lang == std::string(row.tag).substr(0, std::string(row.tag).find('-')))
+      return &row;
+  }
+  return nullptr;
+}
+
+}  // namespace
+
+std::vector<PersonaProfile::Voice> PersonaVoicesForAcceptLanguages(
+    const std::string& accept_languages) {
+  std::vector<PersonaProfile::Voice> out = CurrentPersona().voices;
+  // A deliberately empty persona list (linux / android) stays empty: those
+  // platforms genuinely report getVoices()==[].
+  if (out.empty())
+    return out;
+  // An imported profile's voices are a real capture -- authoritative as-is.
+  if (!IsBuiltinWindowsDefaultVoiceSet(out))
+    return out;
+
+  const LocaleVoiceRow* row =
+      FindLocaleVoiceRow(PrimaryLanguageTag(accept_languages));
+  if (!row)
+    return out;
+
+  std::vector<PersonaProfile::Voice> v;
+  for (const char* name : row->names) {
+    if (!name)
+      break;
+    PersonaProfile::Voice voice;
+    voice.voice_uri = name;
+    voice.name = name;
+    voice.lang = row->lang;
+    voice.local_service = true;
+    // SAPI's default voice is the display-language one, so the FIRST entry of
+    // the matched row is the default -- this is what makes the default voice's
+    // lang agree with navigator.language instead of contradicting it.
+    voice.is_default = v.empty();
+    v.push_back(std::move(voice));
+  }
+  if (v.empty())
+    return out;
+  if (std::string(row->lang) != "en-US") {
+    // Windows carries the en-US base voices in the OS image regardless of
+    // display language, so a localized install reports its pack's voices *and*
+    // these. Never default.
+    for (size_t i = 0; i < out.size() && i < 2; ++i) {
+      PersonaProfile::Voice base_voice = out[i];
+      base_voice.is_default = false;
+      v.push_back(std::move(base_voice));
+    }
+  }
+  return v;
+}
