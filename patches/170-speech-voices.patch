 void SendVoiceListToObserver(
     blink::mojom::SpeechSynthesisVoiceListObserver* observer,
     const std::vector<VoiceData>& voices) {
+  // clearcote: when fingerprinting, present the deterministic persona voice set
+  // (coherent with the persona locale -- an en-US default voice, no en-GB) in
+  // place of the build host's real SAPI voices, whose default voice + ordering
+  // otherwise leak the host locale (an en-GB default under an en-US persona is a
+  // cross-API tell). The persona carries is_default per voice.
+  const base::CommandLine* cc_cmd = base::CommandLine::ForCurrentProcess();
+  if (cc_cmd->HasSwitch("fingerprint")) {
+    const auto& cc_voices = ungoogled::CurrentPersona().voices;
+    if (!cc_voices.empty()) {
+      std::vector<blink::mojom::SpeechSynthesisVoicePtr> cc_out;
+      cc_out.reserve(cc_voices.size());
+      for (const auto& cc_v : cc_voices) {
+        blink::mojom::SpeechSynthesisVoicePtr ov =
+            blink::mojom::SpeechSynthesisVoice::New();
+        ov->voice_uri = cc_v.voice_uri;
+        ov->name = cc_v.name;
+        ov->lang = cc_v.lang;
+        ov->is_local_service = cc_v.local_service;
+        ov->is_default = cc_v.is_default;
+        cc_out.push_back(std::move(ov));
+      }
+      observer->OnSetVoiceList(std::move(cc_out));
+      return;
+    }
+  }
