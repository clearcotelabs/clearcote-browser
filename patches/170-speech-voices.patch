 const HeapVector<Member<SpeechSynthesisVoice>>& SpeechSynthesis::getVoices() {
   // Kick off initialization here to ensure voice list gets populated.
   std::ignore = TryEnsureMojomSynthesis();
+  // clearcote: stock Chrome fills voice_list_ ONLY from the browser process
+  // over mojo (OnSetVoiceList), so on a fresh document the FIRST synchronous
+  // getVoices() returns [] and the real list arrives later, together with a
+  // `voiceschanged` event. Synthesizing the persona list right here would hand
+  // back a complete list on that first call -- an ordering tell that is
+  // independent of whether the voice VALUES are right, and one anti-bot
+  // vendors check for directly. So we never fill synchronously: we only ARM a
+  // deferred backfill, for the case where the browser reply never comes (no
+  // TTS interface bound). On the normal path the browser answers, the backfill
+  // sees a populated list and no-ops -- and because both sides build the list
+  // with ungoogled::PersonaVoicesForAcceptLanguages(), they agree.
+  MaybeArmPersonaVoiceBackfill();
   return voice_list_;
 }
 
+void SpeechSynthesis::MaybeArmPersonaVoiceBackfill() {
+  if (persona_voice_backfill_armed_ || !voice_list_.empty())
+    return;
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch(switches::kFingerprint))
+    return;
+  ExecutionContext* context = GetExecutionContext();
+  if (!context)
+    return;
+  persona_voice_backfill_armed_ = true;
+  context->GetTaskRunner(TaskType::kMiscPlatformAPI)
+      ->PostTask(FROM_HERE,
+                 BindOnce(&SpeechSynthesis::BackfillPersonaVoices,
+                          WrapPersistent(this)));
+}
+
+void SpeechSynthesis::BackfillPersonaVoices() {
+  // The browser process already answered (the normal path): it sent this very
+  // same persona list and fired `voiceschanged`. Nothing to do.
+  if (!voice_list_.empty())
+    return;
+  LocalDOMWindow* window = GetSupplementable();
+  if (!window || !window->GetFrame() || !window->GetFrame()->GetPage())
+    return;
+  // Same locale source as the browser path and as navigator.languages: the
+  // Accept-Language pushed down in RendererPreferences.
+  const std::string accept_languages =
+      window->GetFrame()->GetPage()->GetSettings().GetAcceptLanguages().Utf8();
+  for (const auto& pv :
+       ungoogled::PersonaVoicesForAcceptLanguages(accept_languages)) {
+    voice_list_.push_back(MakeGarbageCollected<SpeechSynthesisVoice>(
+        mojom::blink::SpeechSynthesisVoice::New(
+            String::FromUtf8(pv.voice_uri), String::FromUtf8(pv.name),
+            String::FromUtf8(pv.lang), pv.local_service, pv.is_default)));
+  }
+  // An empty persona list means the persona genuinely has no voices; stock
+  // Chrome would have fired nothing at all here, so neither do we.
+  if (!voice_list_.empty())
+    VoicesDidChange();
+}
