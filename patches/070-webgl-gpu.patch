+bool WebGLRenderingContextBase::ReadBridgePixels(std::vector<uint8_t>* out,
+                                                 int width, int height) {
+  if (bridge_canvas_id_ == 0 || bridge_webgl_unsupported_ || width <= 0 ||
+      height <= 0 || !BridgeAllowedForThisContext())
+    return false;
+  auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!cb || !cb->Connected())
+    return false;
+  std::optional<std::vector<uint8_t>> px =
+      cb->GetImageDataCacheFirst(bridge_canvas_id_, 0, 0, width, height);
+  if (!px || px->size() != static_cast<size_t>(width) * height * 4)
+    return false;
+  // gl.readPixels is bottom-left origin; toDataURL/Skia want top-left -> flip.
+  out->resize(px->size());
+  const size_t row = static_cast<size_t>(width) * 4;
+  for (int y = 0; y < height; ++y) {
+    __builtin_memcpy(out->data() + static_cast<size_t>(y) * row,
+                     px->data() + static_cast<size_t>(height - 1 - y) * row,
+                     row);
+  }
+  return true;
+}
