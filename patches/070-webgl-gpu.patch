+// clearcote: NEVER report a limit higher than the driver can really do -- an
+// upward spoof is falsifiable (the page allocates the texture / links the
+// shader and watches it fail). Clamp the persona value to the live GL cap at
+// read time; equivalent to clamping the persona at init, but robust across
+// multiple contexts and GPU-process restarts, and it costs exactly the one
+// GetIntegerv that stock Chrome already performs for this pname.
+GLint ClampPersonaLimit(gpu::gles2::GLES2Interface* gl,
+                        GLenum pname,
+                        int persona_value) {
+  GLint real = 0;
+  gl->GetIntegerv(pname, &real);
+  GLint v = static_cast<GLint>(persona_value);
+  return (real > 0 && v > real) ? real : v;
+}
+
+GLfloat ClampPersonaLimitF(gpu::gles2::GLES2Interface* gl,
+                           GLenum pname,
+                           float persona_value) {
+  GLfloat real = 0.f;
+  gl->GetFloatv(pname, &real);
+  GLfloat v = static_cast<GLfloat>(persona_value);
+  return (real > 0.f && v > real) ? real : v;
+}
