+uint32_t EnsureBridgeWebGL(blink::canvas_bridge::CanvasBridgeClient* bridge,
+                           uint32_t& id, int width, int height) {
+  if (id == 0) {
+    id = bridge->AllocateCanvasId();
+    blink::canvas_bridge::CreateWebGLMessage create;
+    create.canvas_id = id;
+    create.width = static_cast<uint32_t>(width < 0 ? 0 : width);
+    create.height = static_cast<uint32_t>(height < 0 ? 0 : height);
+    create.context_type = 1;
+    bridge->Send(blink::canvas_bridge::Encode(create));
+  }
+  return id;
+}
+
+void RecordWebGLOp(uint32_t op, std::vector<int32_t> ints,
+                   std::vector<double> floats, uint32_t& id, int width,
+                   int height, std::string str = std::string(),
+                   std::vector<uint8_t> data = std::vector<uint8_t>()) {
+  auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!cb || !cb->Connected())
+    return;
+  blink::canvas_bridge::WebGLOpMessage m;
+  m.canvas_id = EnsureBridgeWebGL(cb, id, width, height);
+  m.op = op;
+  m.ints = std::move(ints);
+  m.floats = std::move(floats);
+  m.str = std::move(str);
+  m.data = std::move(data);
+  cb->Send(blink::canvas_bridge::Encode(m));
+  // Tier 1: draw ops change the rendered surface -> bump version + prefetch.
+  using GLOp = blink::canvas_bridge::WebGLOp;
+  switch (static_cast<GLOp>(op)) {
+    case GLOp::kDrawArrays:
+    case GLOp::kDrawElements:
+    case GLOp::kClear:
+      cb->BumpVersion(m.canvas_id);
+      cb->MaybePrefetch(m.canvas_id,
+                        static_cast<uint32_t>(width < 0 ? 0 : width),
+                        static_cast<uint32_t>(height < 0 ? 0 : height));
+      break;
+    default:
+      break;
+  }
+}
