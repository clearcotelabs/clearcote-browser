+// clearcote (algebraic coherence): MAX_VARYING_VECTORS is the ONE independent
+// varying limit. ANGLE derives MAX_VARYING_COMPONENTS,
+// MAX_VERTEX_OUTPUT_COMPONENTS and MAX_FRAGMENT_INPUT_COMPONENTS from it as
+// exactly 4x (renderer11_utils.cpp GetMaxVaryingVectors), so a page that reads
+// all four and divides catches any drift between a spoofed "vectors" and an
+// unspoofed "components". Only the vectors value lives on the persona; every
+// "components" limit below is computed as 4x THIS, so they cannot disagree.
+GLint PersonaMaxVaryingVectors(gpu::gles2::GLES2Interface* gl) {
+  return ClampPersonaLimit(
+      gl, GL_MAX_VARYING_VECTORS,
+      ungoogled::CurrentPersona().webgl_max_varying_vectors);
+}
