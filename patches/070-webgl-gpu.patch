+
+// GPU deviceID信息可以在这里查询
+// 570.144是驱动号，替换成最新的驱动号
+// https://download.nvidia.com/XFree86/Linux-x86_64/570.144/README/supportedchips.html
+// https://deviceandbrowserinfo.com/data/fingerprints/attribute/webGLRenderer
+// https://devicehunt.com/view/type/pci/vendor/10DE
+
+namespace blink {
+
+using ungoogled::fingerprint::kMacosGpuModelCount;
+
+namespace {
+
+// Returns the appropriate GL_VENDOR string based on platform
+std::string GetGLVendorString(const std::string& platform) {
+  if (platform == "macos") {
+    return "Google Inc. (Apple)";
+  } else if (platform == "linux") {
+    return "Google Inc. (NVIDIA Corporation)";
+  } else {
+    // Windows
+    return "Google Inc. (NVIDIA)";
+  }
+}
+
+// Returns a GL_RENDERER string based on platform and a per-site farbling seed.
+std::string GetGLRendererString(const std::string& platform,
+                                uint64_t effective_seed) {
+  if (platform == "macos") {
+    // Use helper function to get macOS GPU string
+    return GetMacosGpuString(effective_seed % kMacosGpuModelCount);
+  } else if (platform == "linux") {
+    // For Linux, get the basic GPU model but format for Linux
+    size_t model_index = effective_seed % GetGpuCount();
+    // Get the Windows GPU info to extract the model name
+    const GpuInfo& gpu_info = GetGpuInfo(model_index);
+    // Format for Linux (no device ID, different suffix)
+    return GetLinuxGpuString(gpu_info.model_name);
+  } else {
+    // Default to Windows format
+    return GetGpuInfo(effective_seed % GetGpuCount()).renderer_string;
+  }
+}
+
+}  // namespace
+
+// Public functions that will be used in WebGL code
+std::string GetGLVendorStringForFingerprint() {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+
+  // 如果禁用GPU指纹，直接返回空字符串
+  if (command_line->HasSwitch(switches::kDisableGpuFingerprint)) {
+    return "";
+  }
+
+  // 优先级1: 如果指定了 fingerprint-gpu-vendor，直接使用
+  if (command_line->HasSwitch(switches::kFingerprintGpuVendor)) {
+    return command_line->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+  }
+
+  // 优先级2: 如果指定了 fingerprint，根据平台生成
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    std::string platform = "windows";  // Default platform
+    if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+      platform = base::ToLowerASCII(
+          command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+    }
+    return GetGLVendorString(platform);
+  }
+
+  // 优先级3: 都没有指定，返回空字符串（使用默认值）
+  return "";
+}
+
+std::string GetGLRendererStringForFingerprint(uint64_t effective_seed) {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+
+  // 如果禁用GPU指纹，直接返回空字符串
+  if (command_line->HasSwitch(switches::kDisableGpuFingerprint)) {
+    return "";
+  }
+
+  // 优先级1: 如果指定了 fingerprint-gpu-renderer，直接使用
+  if (command_line->HasSwitch(switches::kFingerprintGpuRenderer)) {
+    return command_line->GetSwitchValueASCII(switches::kFingerprintGpuRenderer);
+  }
+
+  // 优先级2: 如果指定了 fingerprint，根据平台和 per-site 种子生成。
+  // 种子由调用方按 eTLD+1 计算（ungoogled::GetFarbleSeed64），使得 GPU 型号
+  // 选择按站点稳定但跨站点解相关。
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    std::string platform = "windows";  // Default platform
+
+    if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+      platform = base::ToLowerASCII(
+          command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+    }
+
+    return GetGLRendererString(platform, effective_seed);
+  }
+
+  // 优先级3: 都没有指定，返回空字符串（使用默认值）
+  return "";
+}
+
+}  // namespace blink
