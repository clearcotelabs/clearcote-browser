+// GL_MAX_VIEWPORT_DIMS is a 2-element query -- GetIntegerv writes two ints, so
+// it needs its own reader (passing a single GLint* would smash the stack).
+GLint ClampPersonaViewportDim(gpu::gles2::GLES2Interface* gl,
+                              int persona_value) {
+  GLint real[2] = {0, 0};
+  gl->GetIntegerv(GL_MAX_VIEWPORT_DIMS, real);
+  const GLint cap = real[0] < real[1] ? real[0] : real[1];
+  GLint v = static_cast<GLint>(persona_value);
+  return (cap > 0 && v > cap) ? cap : v;
+}
