+// Assigns a fresh bridge object id to a just-created WebGL object and records
+// the matching create op so the server builds the same object server-side.
+void RecordWebGLCreate(uint32_t op, WebGLObject* obj, uint32_t& counter,
+                       uint32_t& id, int width, int height) {
+  auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!cb || !cb->Connected())
+    return;
+  obj->SetBridgeId(++counter);
+  blink::canvas_bridge::WebGLOpMessage m;
+  m.canvas_id = EnsureBridgeWebGL(cb, id, width, height);
+  m.op = op;
+  m.ints = {static_cast<int32_t>(obj->BridgeId())};
+  cb->Send(blink::canvas_bridge::Encode(m));
+}
