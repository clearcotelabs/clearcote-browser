+template <typename Rng>
+std::vector<PersonaProfile::MediaDevice> LinuxMediaDevices(Rng& rng) {
+  const std::string grp = "cc-grp-" + base::NumberToString(rng());
+  const std::string mic = "cc-mic-" + base::NumberToString(rng());
+  const std::string spk = "cc-spk-" + base::NumberToString(rng());
+  const std::string mon = "cc-mon-" + base::NumberToString(rng());
+  // PulseAudio/PipeWire enumeration: a 'default' + one physical codec per direction, plus the
+  // characteristic Linux monitor source. No Windows 'Communications -' endpoint / Realtek codec.
+  return {
+      {"audioinput", "Default", "default", grp},
+      {"audioinput", "Built-in Audio Analog Stereo", mic, grp},
+      {"audioinput", "Monitor of Built-in Audio Analog Stereo", mon, grp},
+      {"audiooutput", "Default", "default", grp},
+      {"audiooutput", "Built-in Audio Analog Stereo", spk, grp},
+  };
+}
+
+// clearcote: Android enumerateDevices() roster -- a default mic + speaker plus a
+// back/front camera pair with the real Chrome-on-Android "camera2 N, facing ..."
+// label format. No Windows Realtek/Communications endpoints. Raw ids are seed-
+// derived; the per-origin HMAC hashes them and blanks labels pre-permission.
+template <typename Rng>
+std::vector<PersonaProfile::MediaDevice> AndroidMediaDevices(Rng& rng) {
+  const std::string agrp = "cc-agrp-" + base::NumberToString(rng());
+  const std::string cam_b = "cc-cam-" + base::NumberToString(rng());
+  const std::string cam_f = "cc-cam-" + base::NumberToString(rng());
+  const std::string cgrp_b = "cc-cgrp-" + base::NumberToString(rng());
+  const std::string cgrp_f = "cc-cgrp-" + base::NumberToString(rng());
+  return {
+      {"audioinput", "Default", "default", agrp},
+      {"audiooutput", "Default", "default", agrp},
+      {"videoinput", "camera2 0, facing back", cam_b, cgrp_b},
+      {"videoinput", "camera2 1, facing front", cam_f, cgrp_f},
+  };
+}
+
+PersonaProfile DerivePersona(uint64_t seed) {
+  // SplitMix64 decorrelates weak seeds (1, 2, 3 otherwise produce visibly
+  // similar mt19937_64 streams).
+  uint64_t mixed = seed + 0x9E3779B97F4A7C15ull;
+  mixed = (mixed ^ (mixed >> 30)) * 0xBF58476D1CE4E5B9ull;
+  mixed = (mixed ^ (mixed >> 27)) * 0x94D049BB133111EBull;
+  mixed = mixed ^ (mixed >> 31);
+
+  std::mt19937_64 rng(mixed);
+
+  PersonaProfile p;
+  p.persona_seed = mixed;
+
+  // Identity.
+  const ChromeVer& cv = WeightedPick(rng, kChromeVersions);
+  p.chrome_major_version = cv.major;
+  p.chrome_full_version = cv.full;
+
+  // Hardware: tier first, then correlated cores + RAM.
+  std::array<double, kHwTiers.size()> tier_weights;
+  for (size_t i = 0; i < kHwTiers.size(); ++i) {
+    tier_weights[i] = kHwTiers[i].weight;
+  }
+  std::discrete_distribution<size_t> tier_dist(tier_weights.begin(),
+                                               tier_weights.end());
+  const HwTier& tier = kHwTiers[tier_dist(rng)].value;
+  p.hardware_concurrency = WeightedPick(rng, tier.hc);
+  p.device_memory_gb = WeightedPick(rng, tier.mem);
+
+  // Screen.
+  const ScreenSize& sc = WeightedPick(rng, kScreens);
+  p.screen_width = sc.w;
+  p.screen_height = sc.h;
+  p.avail_screen_width = sc.w;
+  p.avail_screen_height = sc.avail_h;
+  p.color_depth = WeightedPick(rng, kColorDepths);
+  p.device_pixel_ratio = 1.0;
+
+  // WebGL identity (coherent Intel UHD 770 default; see kWebGLGPUs).
+  const WebGLGPU& gpu = kWebGLGPUs[0].value;
+  p.webgl_vendor = gpu.vendor;
+  p.webgl_renderer = gpu.renderer;
+
+  // Default Windows voice set (closes the getVoices()=0 tell); a profile overrides.
+  p.voices = {
+      {"Microsoft David - English (United States)",
+       "Microsoft David - English (United States)", "en-US", true, true},
+      {"Microsoft Zira - English (United States)",
+       "Microsoft Zira - English (United States)", "en-US", true, false},
+      {"Microsoft Mark - English (United States)",
+       "Microsoft Mark - English (United States)", "en-US", true, false},
+  };
+
+  // clearcote: canonical desktop WebGPU adapter limits -- the spec-tier
+  // maximums shared by modern desktop GPUs (a real capture), so they read as
+  // genuine hardware and stay coherent with the spoofed WebGL GPU regardless
+  // of the host's actual GPU. An imported profile's webgpu.limits overrides
+  // individual entries (see ApplyProfileOverride).
+  p.webgpu_limits = {
+      {"maxTextureDimension1D", 16384ull},
+      {"maxTextureDimension2D", 16384ull},
+      {"maxTextureDimension3D", 2048ull},
+      {"maxTextureArrayLayers", 2048ull},
+      {"maxBindGroups", 4ull},
+      {"maxBindGroupsPlusVertexBuffers", 24ull},
+      {"maxBindingsPerBindGroup", 1000ull},
+      {"maxDynamicUniformBuffersPerPipelineLayout", 10ull},
+      {"maxDynamicStorageBuffersPerPipelineLayout", 8ull},
+      {"maxSampledTexturesPerShaderStage", 48ull},
+      {"maxSamplersPerShaderStage", 16ull},
+      {"maxStorageBuffersPerShaderStage", 16ull},
+      {"maxStorageTexturesPerShaderStage", 8ull},
+      {"maxUniformBuffersPerShaderStage", 12ull},
+      {"maxUniformBufferBindingSize", 65536ull},
+      {"maxStorageBufferBindingSize", 2147483644ull},
+      {"minUniformBufferOffsetAlignment", 256ull},
+      {"minStorageBufferOffsetAlignment", 256ull},
+      {"maxVertexBuffers", 8ull},
+      {"maxBufferSize", 2147483648ull},
+      {"maxVertexAttributes", 30ull},
+      {"maxVertexBufferArrayStride", 2048ull},
+      {"maxInterStageShaderVariables", 28ull},
+      {"maxColorAttachments", 8ull},
+      {"maxColorAttachmentBytesPerSample", 128ull},
+      {"maxComputeWorkgroupStorageSize", 32768ull},
+      {"maxComputeInvocationsPerWorkgroup", 1024ull},
+      {"maxComputeWorkgroupSizeX", 1024ull},
+      {"maxComputeWorkgroupSizeY", 1024ull},
+      {"maxComputeWorkgroupSizeZ", 64ull},
+      {"maxComputeWorkgroupsPerDimension", 65535ull},
+      {"maxStorageBuffersInFragmentStage", 16ull},
+      {"maxStorageTexturesInFragmentStage", 8ull},
+      {"maxStorageBuffersInVertexStage", 16ull},
+      {"maxStorageTexturesInVertexStage", 8ull},
+  };
+
+  // clearcote: canonical desktop media-codec support -- a modern Windows Chrome
+  // on the default Intel UHD 770 iGPU (HW decode for H.264/VP8/VP9/AV1/HEVC).
+  // {supported, smooth, powerEfficient}. Overrides the host's real
+  // MediaCapabilities answers so they stay coherent with the spoofed GPU
+  // regardless of the build box's actual hardware. An imported profile's
+  // mediaCapabilities/codecs dict overrides individual entries.
+  p.media_codecs = {
+      {"h264", {true, true, true}},
+      {"vp8", {true, true, true}},
+      {"vp9", {true, true, true}},
+      {"av1", {true, true, true}},
+      {"hevc", {true, true, true}},
+  };
+
+  // clearcote: enumerateDevices() persona device set -- a coherent real Windows
+  // desktop with one onboard Realtek audio codec and no webcam (the most common,
+  // lowest-entropy config). One shared group_id (one physical codec). Raw ids are
+  // seed-derived so different --fingerprint seeds differ; the per-origin HMAC
+  // (TranslateMediaDeviceInfo) hashes them per site and blanks labels pre-grant.
+  // The literal "default"/"communications" ids pass through unhashed. An imported
+  // profile's mediaDevices list overrides this (see ApplyProfileOverride).
+  {
+    const std::string raw_mic = "cc-mic-" + base::NumberToString(rng());
+    const std::string raw_spk = "cc-spk-" + base::NumberToString(rng());
+    const std::string raw_grp = "cc-grp-" + base::NumberToString(rng());
+    p.media_devices = {
+        {"audioinput", "Default - Microphone (Realtek(R) Audio)", "default", raw_grp},
+        {"audioinput", "Communications - Microphone (Realtek(R) Audio)",
+         "communications", raw_grp},
+        {"audioinput", "Microphone (Realtek(R) Audio)", raw_mic, raw_grp},
+        {"audiooutput", "Default - Speakers (Realtek(R) Audio)", "default", raw_grp},
+        {"audiooutput", "Communications - Speakers (Realtek(R) Audio)",
+         "communications", raw_grp},
+        {"audiooutput", "Speakers (Realtek(R) Audio)", raw_spk, raw_grp},
+    };
+  }
+
+  ApplyProfileOverride(&p);
+
+  // clearcote: an explicit --fingerprint-gpu-vendor/-renderer overrides the seed-/profile-
+  // derived GPU (precedence: switch > imported profile > seed); WebGL getParameter reads these.
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  // clearcote: the seed/profile persona defaults are Windows-shaped (ANGLE/D3D11 GPU, Microsoft
+  // SAPI voices, Realtek/WASAPI audio devices). On a Linux persona, swap each to its coherent
+  // Linux form so no field contradicts platform=Linux. Only rewrite a still-Windows default (an
+  // imported Linux/mac profile is left intact); an explicit --fingerprint-gpu-renderer wins below.
+  if (cmd->HasSwitch(switches::kFingerprintPlatform) &&
+      cmd->GetSwitchValueASCII(switches::kFingerprintPlatform) == "linux") {
+    if (p.webgl_renderer.find("Direct3D") != std::string::npos)
+      p.webgl_renderer = LinuxWebGLRenderer(p.webgl_vendor);
+    // A real Chrome-on-Linux with no speech-dispatcher reports getVoices()==[]; never Windows
+    // SAPI names. Empty is a common, coherent Linux state; drop only the Windows default.
+    if (!p.voices.empty() && p.voices.front().name.rfind("Microsoft", 0) == 0)
+      p.voices.clear();
+    // enumerateDevices: Pulse/PipeWire shape (no Windows 'Communications -' endpoint / Realtek).
+    if (!p.media_devices.empty() &&
+        p.media_devices.front().label.find("Realtek") != std::string::npos)
+      p.media_devices = LinuxMediaDevices(rng);
+  }
+  // clearcote: Android persona. Unlike linux (which rewrites only GPU/voices/
+  // devices and keeps the Windows screen/pointer/touch), android inverts the
+  // desktop shape structurally, so it overwrites screen/DPR/mobile/touch/GPU +
+  // the GLES limit table from one atomic device row.
+  if (cmd->HasSwitch(switches::kFingerprintPlatform) &&
+      cmd->GetSwitchValueASCII(switches::kFingerprintPlatform) == "android") {
+    const AndroidDevice& dev = WeightedPick(rng, kAndroidDevices);
+    // Portrait screen; Android reports availWidth/Height == the full screen.
+    p.screen_width = dev.screen_w;
+    p.screen_height = dev.screen_h;
+    p.avail_screen_width = dev.screen_w;
+    p.avail_screen_height = dev.screen_h;
+    p.color_depth = 24;
+    p.device_pixel_ratio = dev.dpr;
+    p.mobile = true;
+    p.max_touch_points = dev.max_touch;
+    p.pointer_coarse = true;
+    p.hover_none = true;
+    p.orientation_type = "portrait-primary";
+    p.orientation_angle = 0;
+    p.dynamic_range_high = true;
+    p.hardware_concurrency = dev.hc;
+    p.device_memory_gb = static_cast<float>(dev.mem_gb);
+    p.webgl_vendor = dev.gl_vendor;
+    p.webgl_renderer = dev.gl_renderer;
+    p.android_model = dev.model;
+    p.android_platform_version = dev.platform_version;
+    p.css_color_gamut = dev.color_gamut;
+    // Mobile GLES 3.2 getParameter limit table (WebGL getParameter reads these).
+    // NOTE: raises the bar but does NOT change rendered pixels (still desktop GPU
+    // / SwiftShader). Values are common mobile-GLES; verify vs a real-device
+    // capture before ship (see report).
+    p.webgl_max_texture_size = dev.gl_max_texture_size;
+    p.webgl_max_cube_map_texture_size = dev.gl_max_texture_size;
+    p.webgl_max_renderbuffer_size = dev.gl_max_texture_size;
+    p.webgl_max_viewport_dim = dev.gl_max_texture_size;
+    p.webgl_max_vertex_uniform_vectors = 1024;
+    p.webgl_max_fragment_uniform_vectors = 1024;
+    p.webgl_max_varying_vectors = 31;
+    p.webgl_max_combined_texture_image_units = 96;
+    p.webgl_max_samples = 4;
+    p.webgl_max_uniform_buffer_bindings = 24;
+    // TTS: a Chrome-on-Android with no bound local engine reports getVoices()==[]
+    // (mirror the linux fix); never leak the Windows SAPI default.
+    if (!p.voices.empty() && p.voices.front().name.rfind("Microsoft", 0) == 0)
+      p.voices.clear();
+    // enumerateDevices: phone-shaped roster.
+    p.media_devices = AndroidMediaDevices(rng);
+  }
+  if (cmd->HasSwitch(switches::kFingerprintGpuVendor))
+    p.webgl_vendor = cmd->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+  if (cmd->HasSwitch(switches::kFingerprintGpuRenderer))
+    p.webgl_renderer = cmd->GetSwitchValueASCII(switches::kFingerprintGpuRenderer);
+  // clearcote: --disable-gpu-fingerprint presents the REAL backend. WebGL getParameter checks
+  // webgl_real and routes the GPU strings/params/extensions to the stock getters, and the
+  // readback noise is skipped -- so the reported GPU matches the rendered pixels (no spoof to
+  // cross-check). Top precedence over seed/profile/gpu-switch; webgl_vendor stays intact so the
+  // WebGPU identity below remains coherent.
+  if (cmd->HasSwitch(switches::kDisableGpuFingerprint))
+    p.webgl_real = true;
+  // clearcote: explicit --fingerprint-webgpu-vendor/-architecture overrides the
+  // profile-/seed-derived WebGPU identity (precedence: switch > profile > seed).
+  if (cmd->HasSwitch("fingerprint-webgpu-vendor"))
+    p.webgpu_vendor = cmd->GetSwitchValueASCII("fingerprint-webgpu-vendor");
+  if (cmd->HasSwitch("fingerprint-webgpu-architecture"))
+    p.webgpu_architecture = cmd->GetSwitchValueASCII("fingerprint-webgpu-architecture");
+  // If neither a profile nor a switch set the WebGPU identity, derive it from the
+  // FINAL WebGL GPU (after the gpu-vendor switch/profile) so navigator.gpu always
+  // matches the WebGL UNMASKED vendor: lowercase WebGPU vendor + canonical arch.
+  if (p.webgpu_vendor.empty() || p.webgpu_architecture.empty()) {
+    std::string cc_v, cc_a;
+    if (p.webgl_vendor.find("NVIDIA") != std::string::npos) {
+      cc_v = "nvidia"; cc_a = "ampere";
+    } else if (p.webgl_vendor.find("AMD") != std::string::npos ||
+               p.webgl_vendor.find("ATI") != std::string::npos ||
+               p.webgl_vendor.find("Radeon") != std::string::npos) {
+      cc_v = "amd"; cc_a = "rdna2";
+    } else if (p.webgl_vendor.find("ARM") != std::string::npos ||
+               p.webgl_vendor.find("Mali") != std::string::npos) {
+      // clearcote: Android Mali persona -> ARM Valhall (Mali-G710/G68), so
+      // navigator.gpu stays coherent with the WebGL ARM string instead of
+      // falling through to "intel" (a direct contradiction).
+      cc_v = "arm"; cc_a = "valhall";
+    } else if (p.webgl_vendor.find("Qualcomm") != std::string::npos ||
+               p.webgl_vendor.find("Adreno") != std::string::npos) {
+      cc_v = "qualcomm"; cc_a = "adreno";
+    } else {
+      cc_v = "intel"; cc_a = "gen-12-lp";
+    }
+    if (p.webgpu_vendor.empty()) p.webgpu_vendor = cc_v;
+    if (p.webgpu_architecture.empty()) p.webgpu_architecture = cc_a;
+  }
+  return p;
+}
+
+const PersonaProfile& CurrentPersona() {
+  // Intentionally leaked process-lifetime singleton (no exit-time destructor),
+  // lazily initialized once per process.
+  static PersonaProfile* profile = nullptr;
+  static std::once_flag once;
+  std::call_once(once, [] {
+    profile = new PersonaProfile(DerivePersona(SeedFromCommandLine()));
+  });
+  return *profile;
+}
