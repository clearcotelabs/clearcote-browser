+// clearcote: Linux (ANGLE-over-GL / Mesa) renderer equivalents of the Windows GPU pool, so a
+// Linux persona reports an OpenGL/Mesa UNMASKED_RENDERER instead of a Windows-only Direct3D11
+// string (which would contradict navigator.platform=Linux).
+std::string LinuxWebGLRenderer(const std::string& vendor) {
+  if (vendor.find("NVIDIA") != std::string::npos)
+    return "ANGLE (NVIDIA, NVIDIA GeForce RTX 3060/PCIe/SSE2, OpenGL 4.6.0 NVIDIA 535.146.02)";
+  if (vendor.find("AMD") != std::string::npos || vendor.find("Radeon") != std::string::npos)
+    return "ANGLE (AMD, AMD Radeon Graphics (radeonsi, raphael_mendocino, LLVM 15.0.7, DRM 3.54, "
+           "6.5.0-generic), OpenGL 4.6 (Core Profile) Mesa 23.2.1-1ubuntu3.1~22.04.2)";
+  return "ANGLE (Intel, Mesa Intel(R) UHD Graphics 770 (RPL-S), OpenGL 4.6 (Core Profile) "
+         "Mesa 23.2.1-1ubuntu3.1~22.04.2)";
+}
