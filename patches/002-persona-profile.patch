+// Parse the persona seed from the existing --fingerprint switch. Numeric values
+// are used directly; non-numeric values are FNV-1a hashed to a stable uint64
+// (matching the per-site seed parse used elsewhere, and stable across builds,
+// unlike std::hash) so the browser and every renderer derive the SAME persona.
+uint64_t SeedFromCommandLine() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch(switches::kFingerprint)) {
+    return 0;
+  }
+  const std::string raw = cmd->GetSwitchValueASCII(switches::kFingerprint);
+  uint64_t parsed = 0;
+  if (base::StringToUint64(raw, &parsed)) {
+    return parsed;
+  }
+  uint64_t h = 14695981039346656037ULL;  // FNV-1a offset basis
+  for (unsigned char c : raw) {
+    h ^= c;
+    h *= 1099511628211ULL;  // FNV prime
+  }
+  return h;
+}
