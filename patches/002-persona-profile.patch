+template <typename T>
+struct WeightedEntry {
+  T value;
+  double weight;
+};
+
+// Weighted picker over std::array<WeightedEntry<T>, N>.
+template <typename T, size_t N>
+const T& WeightedPick(std::mt19937_64& rng,
+                      const std::array<WeightedEntry<T>, N>& pool) {
+  std::array<double, N> weights;
+  for (size_t i = 0; i < N; ++i) {
+    weights[i] = pool[i].weight;
+  }
+  std::discrete_distribution<size_t> dist(weights.begin(), weights.end());
+  return pool[dist(rng)].value;
+}
+
+struct ChromeVer {
+  unsigned major;
+  const char* full;
+};
+struct ScreenSize {
+  int w;
+  int h;
+  int avail_h;  // height minus a realistic Windows taskbar
+};
+struct WebGLGPU {
+  const char* vendor;
+  const char* renderer;
+};
+
+// Chrome version pool — clearcote's 149 line (mirrors fingerprint_data.h).
+constexpr std::array<WeightedEntry<ChromeVer>, 4> kChromeVersions = {{
+    {{149, "149.0.7827.114"}, 0.55},
+    {{149, "149.0.7827.89"}, 0.20},
+    {{149, "149.0.7827.66"}, 0.15},
+    {{149, "149.0.7827.58"}, 0.10},
+}};
+
+// Windows desktop resolutions (StatCounter / Steam-survey weighted). avail_h is
+// the work area = height minus the taskbar (~40px) so screen.availHeight is
+// plausible rather than == height.
+constexpr std::array<WeightedEntry<ScreenSize>, 9> kScreens = {{
+    {{1920, 1080, 1040}, 0.34},
+    {{1920, 1080, 1080}, 0.06},  // auto-hide taskbar
+    {{1366, 768, 728}, 0.15},
+    {{1536, 864, 824}, 0.12},
+    {{1440, 900, 860}, 0.05},
+    {{2560, 1440, 1400}, 0.10},
+    {{1680, 1050, 1010}, 0.04},
+    {{1600, 900, 860}, 0.04},
+    {{3840, 2160, 2120}, 0.10},
+}};
+
+// Hardware tiers: pick a tier first, then draw cores + RAM from that tier's
+// constrained pools so the (cores, RAM) pair is one a real desktop ships. Flat
+// independent sampling produces off-distribution combos (e.g. 20 cores + 16 GB,
+// 4 cores + 32 GB) that anti-detect ML flags as tampered. Weights skew toward
+// entry/mainstream (incl. the cloud-Windows-VPS shape) per Steam Hardware
+// Survey aggregates.
+struct HwTier {
+  std::array<WeightedEntry<unsigned>, 3> hc;
+  std::array<WeightedEntry<float>, 2> mem;
+};
+constexpr std::array<WeightedEntry<HwTier>, 4> kHwTiers = {{
+    // Tier 1 — entry laptop / older desktop / cloud Win VPS.
+    {{{{{4u, 0.55}, {6u, 0.20}, {8u, 0.25}}}, {{{4.0f, 0.30}, {8.0f, 0.70}}}},
+     0.62},
+    // Tier 2 — mainstream desktop / gaming laptop.
+    {{{{{8u, 0.60}, {12u, 0.25}, {16u, 0.15}}}, {{{8.0f, 0.40}, {16.0f, 0.60}}}},
+     0.30},
+    // Tier 3 — high-end gaming desktop.
+    {{{{{12u, 0.30}, {16u, 0.55}, {20u, 0.15}}},
+      {{{16.0f, 0.55}, {32.0f, 0.45}}}},
+     0.06},
+    // Tier 4 — enthusiast / workstation (rare).
+    {{{{{16u, 0.30}, {20u, 0.40}, {24u, 0.30}}},
+      {{{32.0f, 0.65}, {64.0f, 0.35}}}},
+     0.02},
+}};
+
+// Color depth: Win11 desktops are overwhelmingly 24; HDR / multi-monitor can be
+// 30/32. Keep 24 dominant so a Windows persona never reports the rare value too
+// often (which is itself a tell).
+constexpr std::array<WeightedEntry<unsigned>, 3> kColorDepths = {{
+    {24u, 0.92},
+    {30u, 0.04},
+    {32u, 0.04},
+}};
+
+// Windows consumer GPU pool (ANGLE/D3D11 strings). Index 0 (Intel UHD 770) is
+// the coherent default for the SwiftShader backend: empirically a low-end IGP
+// claim scores far lower on VM/anti-detect classifiers than claiming a discrete
+// GPU whose pixel output software rendering cannot match. NVIDIA/AMD are kept
+// for future per-seed GPU selection; every persona currently uses index 0.
+constexpr std::array<WeightedEntry<WebGLGPU>, 3> kWebGLGPUs = {{
+    {{"Google Inc. (Intel)",
+      "ANGLE (Intel, Intel(R) UHD Graphics 770 (0xA780) Direct3D11 vs_5_0 "
+      "ps_5_0, D3D11)"},
+     0.50},
+    {{"Google Inc. (NVIDIA)",
+      "ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0, D3D11)"},
+     0.35},
+    {{"Google Inc. (AMD)",
+      "ANGLE (AMD, AMD Radeon(TM) Graphics (0x000015D8) Direct3D11 vs_5_0 "
+      "ps_5_0, D3D11)"},
+     0.15},
+}};
+
+// Parse the persona seed from the existing --fingerprint switch. Numeric values
+// are used directly; non-numeric values are FNV-1a hashed to a stable uint64
+// (matching the per-site seed parse used elsewhere, and stable across builds,
+// unlike std::hash) so the browser and every renderer derive the SAME persona.
+uint64_t SeedFromCommandLine() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch(switches::kFingerprint)) {
+    return 0;
+  }
+  const std::string raw = cmd->GetSwitchValueASCII(switches::kFingerprint);
+  uint64_t parsed = 0;
+  if (base::StringToUint64(raw, &parsed)) {
+    return parsed;
+  }
+  uint64_t h = 14695981039346656037ULL;  // FNV-1a offset basis
+  for (unsigned char c : raw) {
+    h ^= c;
+    h *= 1099511628211ULL;  // FNV prime
+  }
+  return h;
+}
+
+// clearcote: when --fingerprint-profile=<gzip+base64 JSON> is set (a captured real
+// fingerprint), override the seed-derived persona fields with the imported values.
+// Absent fields keep their DerivePersona() value, so partial profiles stay coherent.
+void ApplyProfileOverride(PersonaProfile* p) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch(switches::kFingerprintProfile))
+    return;
+  std::string gz;
+  if (!base::Base64Decode(cmd->GetSwitchValueASCII(switches::kFingerprintProfile), &gz))
+    return;
+  std::string json;
+  if (!compression::GzipUncompress(gz, &json))
+    return;
+  auto parsed = base::JSONReader::ReadDict(json, base::JSON_PARSE_RFC);
+  if (!parsed)
+    return;
+  const base::DictValue& d = *parsed;
+  auto num = [](const base::DictValue& dd, const char* k) -> std::optional<double> {
+    if (auto v = dd.FindDouble(k)) return v;
+    if (auto v = dd.FindInt(k)) return static_cast<double>(*v);
+    return std::nullopt;
+  };
+  if (auto v = d.FindInt("hardware_concurrency")) p->hardware_concurrency = *v;
+  if (auto v = num(d, "device_memory")) p->device_memory_gb = static_cast<float>(*v);
+  if (const base::DictValue* s = d.FindDict("screen")) {
+    if (auto v = s->FindInt("width")) p->screen_width = *v;
+    if (auto v = s->FindInt("height")) p->screen_height = *v;
+    if (auto v = s->FindInt("avail_width")) p->avail_screen_width = *v;
+    if (auto v = s->FindInt("avail_height")) p->avail_screen_height = *v;
+    if (auto v = s->FindInt("color_depth")) p->color_depth = *v;
+    if (auto v = num(*s, "device_pixel_ratio")) p->device_pixel_ratio = *v;
+  }
+  if (const base::DictValue* w = d.FindDictByDottedPath("webgl.webgl1")) {
+    if (const base::DictValue* dbg = w->FindDict("debug")) {
+      if (const std::string* s = dbg->FindString("UNMASKED_VENDOR_WEBGL")) p->webgl_vendor = *s;
+      if (const std::string* s = dbg->FindString("UNMASKED_RENDERER_WEBGL")) p->webgl_renderer = *s;
+    }
+    if (const base::DictValue* pr = w->FindDict("parameters")) {
+      auto gi = [&](const char* k, int* dst) { if (auto v = pr->FindInt(k)) *dst = *v; };
+      gi("MAX_TEXTURE_SIZE", &p->webgl_max_texture_size);
+      gi("MAX_CUBE_MAP_TEXTURE_SIZE", &p->webgl_max_cube_map_texture_size);
+      gi("MAX_RENDERBUFFER_SIZE", &p->webgl_max_renderbuffer_size);
+      gi("MAX_VARYING_VECTORS", &p->webgl_max_varying_vectors);
+      gi("MAX_VERTEX_UNIFORM_VECTORS", &p->webgl_max_vertex_uniform_vectors);
+      gi("MAX_FRAGMENT_UNIFORM_VECTORS", &p->webgl_max_fragment_uniform_vectors);
+      gi("MAX_COMBINED_TEXTURE_IMAGE_UNITS", &p->webgl_max_combined_texture_image_units);
+    }
+  }
+  if (const base::DictValue* w2 = d.FindDictByDottedPath("webgl.webgl2")) {
+    if (const base::DictValue* pr = w2->FindDict("parameters")) {
+      auto gi = [&](const char* k, int* dst) { if (auto v = pr->FindInt(k)) *dst = *v; };
+      gi("MAX_3D_TEXTURE_SIZE", &p->webgl_max_3d_texture_size);
+      gi("MAX_ARRAY_TEXTURE_LAYERS", &p->webgl_max_array_texture_layers);
+      gi("MAX_DRAW_BUFFERS", &p->webgl_max_draw_buffers);
+      gi("MAX_COLOR_ATTACHMENTS", &p->webgl_max_color_attachments);
+      gi("MAX_SAMPLES", &p->webgl_max_samples);
+      gi("MAX_VERTEX_UNIFORM_BLOCKS", &p->webgl_max_vertex_uniform_blocks);
+      gi("MAX_FRAGMENT_UNIFORM_BLOCKS", &p->webgl_max_fragment_uniform_blocks);
+      gi("MAX_COMBINED_UNIFORM_BLOCKS", &p->webgl_max_combined_uniform_blocks);
+      gi("MAX_UNIFORM_BUFFER_BINDINGS", &p->webgl_max_uniform_buffer_bindings);
+      gi("MAX_VERTEX_UNIFORM_COMPONENTS", &p->webgl_max_vertex_uniform_components);
+      gi("MAX_FRAGMENT_UNIFORM_COMPONENTS", &p->webgl_max_fragment_uniform_components);
+      if (auto v = num(*pr, "MAX_TEXTURE_LOD_BIAS")) p->webgl_max_texture_lod_bias = static_cast<float>(*v);
+    }
+  }
+  if (const base::DictValue* a = d.FindDict("audio")) {
+    if (auto v = num(*a, "BaseAudioContextSampleRate")) p->audio_sample_rate = static_cast<float>(*v);
+    if (auto v = num(*a, "AudioContextBaseLatency")) p->audio_base_latency = *v;
+    if (auto v = num(*a, "AudioContextOutputLatency")) p->audio_output_latency = *v;
+  }
+  if (const base::DictValue* pm = d.FindDict("perf_memory")) {
+    if (auto v = num(*pm, "jsHeapSizeLimit"))
+      p->js_heap_size_limit = static_cast<uint64_t>(*v);
+  }
+  if (const std::string* uav = d.FindStringByDottedPath("navigator.uadata.high_entropy.uaFullVersion")) {
+    if (!uav->empty()) {
+      p->chrome_full_version = *uav;
+      int maj = 0; base::StringToInt(uav->substr(0, uav->find('.')), &maj);
+      if (maj > 0) p->chrome_major_version = static_cast<unsigned>(maj);
+    }
+  }
+  if (const base::ListValue* voices = d.FindList("speech")) {
+    if (!voices->empty()) {
+      p->voices.clear();
+      for (const base::Value& item : *voices) {
+        const base::DictValue* vd = item.GetIfDict();
+        if (!vd)
+          continue;
+        PersonaProfile::Voice voice;
+        if (const std::string* s = vd->FindString("voice_uri")) voice.voice_uri = *s;
+        if (const std::string* s = vd->FindString("name")) voice.name = *s;
+        if (const std::string* s = vd->FindString("lang")) voice.lang = *s;
+        if (auto bv = vd->FindBool("local_service")) voice.local_service = *bv;
+        if (auto bv = vd->FindBool("default")) voice.is_default = *bv;
+        p->voices.push_back(std::move(voice));
+      }
+    }
+  }
+  if (const base::DictValue* fonts = d.FindDict("fonts")) {
+    if (const base::ListValue* detected = fonts->FindList("detected")) {
+      if (!detected->empty()) {
+        p->fonts.clear();
+        for (const base::Value& item : *detected) {
+          if (const std::string* s = item.GetIfString())
+            p->fonts.push_back(*s);
+        }
+      }
+    }
+  }
+  if (const base::DictValue* w1 = d.FindDictByDottedPath("webgl.webgl1")) {
+    if (const base::DictValue* pr = w1->FindDict("parameters")) {
+      auto gi = [&](const char* k, int* dst) { if (auto v = pr->FindInt(k)) *dst = *v; };
+      gi("RED_BITS", &p->webgl_red_bits);
+      gi("GREEN_BITS", &p->webgl_green_bits);
+      gi("BLUE_BITS", &p->webgl_blue_bits);
+      gi("ALPHA_BITS", &p->webgl_alpha_bits);
+      gi("DEPTH_BITS", &p->webgl_depth_bits);
+      gi("STENCIL_BITS", &p->webgl_stencil_bits);
+      gi("SUBPIXEL_BITS", &p->webgl_subpixel_bits);
+      gi("SAMPLE_BUFFERS", &p->webgl_sample_buffers);
+      gi("SAMPLES", &p->webgl_samples);
+      if (auto v = pr->FindDouble("MAX_TEXTURE_MAX_ANISOTROPY_EXT"))
+        p->webgl_max_texture_max_anisotropy = static_cast<float>(*v);
+      auto garr = [&](const char* k, int* mn, int* mx) {
+        const base::ListValue* a = pr->FindList(k);
+        if (!a || a->size() < 2) return;
+        if (auto i0 = (*a)[0].GetIfInt()) *mn = *i0;
+        else if (auto d0 = (*a)[0].GetIfDouble()) *mn = static_cast<int>(*d0);
+        if (auto i1 = (*a)[1].GetIfInt()) *mx = *i1;
+        else if (auto d1 = (*a)[1].GetIfDouble()) *mx = static_cast<int>(*d1);
+      };
+      garr("ALIASED_LINE_WIDTH_RANGE", &p->webgl_aliased_line_width_range_min,
+           &p->webgl_aliased_line_width_range_max);
+      garr("ALIASED_POINT_SIZE_RANGE", &p->webgl_aliased_point_size_range_min,
+           &p->webgl_aliased_point_size_range_max);
+    }
+    if (const base::ListValue* ext = w1->FindList("extensions")) {
+      if (!ext->empty()) {
+        p->webgl_extensions.clear();
+        for (const base::Value& item : *ext)
+          if (const std::string* s = item.GetIfString()) p->webgl_extensions.push_back(*s);
+      }
+    }
+  }
+  if (const base::DictValue* css = d.FindDict("css")) {
+    if (auto v = css->FindBool("color-gamut:rec2020"); v && *v) p->css_color_gamut = "rec2020";
+    else if (auto v = css->FindBool("color-gamut:p3"); v && *v) p->css_color_gamut = "p3";
+    else if (auto v = css->FindBool("color-gamut:srgb"); v && *v) p->css_color_gamut = "srgb";
+  }
+}
+
+}  // namespace
+
+PersonaProfile DerivePersona(uint64_t seed) {
+  // SplitMix64 decorrelates weak seeds (1, 2, 3 otherwise produce visibly
+  // similar mt19937_64 streams).
+  uint64_t mixed = seed + 0x9E3779B97F4A7C15ull;
+  mixed = (mixed ^ (mixed >> 30)) * 0xBF58476D1CE4E5B9ull;
+  mixed = (mixed ^ (mixed >> 27)) * 0x94D049BB133111EBull;
+  mixed = mixed ^ (mixed >> 31);
+
+  std::mt19937_64 rng(mixed);
+
+  PersonaProfile p;
+  p.persona_seed = mixed;
+
+  // Identity.
+  const ChromeVer& cv = WeightedPick(rng, kChromeVersions);
+  p.chrome_major_version = cv.major;
+  p.chrome_full_version = cv.full;
+
+  // Hardware: tier first, then correlated cores + RAM.
+  std::array<double, kHwTiers.size()> tier_weights;
+  for (size_t i = 0; i < kHwTiers.size(); ++i) {
+    tier_weights[i] = kHwTiers[i].weight;
+  }
+  std::discrete_distribution<size_t> tier_dist(tier_weights.begin(),
+                                               tier_weights.end());
+  const HwTier& tier = kHwTiers[tier_dist(rng)].value;
+  p.hardware_concurrency = WeightedPick(rng, tier.hc);
+  p.device_memory_gb = WeightedPick(rng, tier.mem);
+
+  // Screen.
+  const ScreenSize& sc = WeightedPick(rng, kScreens);
+  p.screen_width = sc.w;
+  p.screen_height = sc.h;
+  p.avail_screen_width = sc.w;
+  p.avail_screen_height = sc.avail_h;
+  p.color_depth = WeightedPick(rng, kColorDepths);
+  p.device_pixel_ratio = 1.0;
+
+  // WebGL identity (coherent Intel UHD 770 default; see kWebGLGPUs).
+  const WebGLGPU& gpu = kWebGLGPUs[0].value;
+  p.webgl_vendor = gpu.vendor;
+  p.webgl_renderer = gpu.renderer;
+
+  // Default Windows voice set (closes the getVoices()=0 tell); a profile overrides.
+  p.voices = {
+      {"Microsoft David Desktop - English (United States)",
+       "Microsoft David Desktop - English (United States)", "en-US", true, true},
+      {"Microsoft Zira Desktop - English (United States)",
+       "Microsoft Zira Desktop - English (United States)", "en-US", true, false},
+      {"Microsoft Mark - English (United States)",
+       "Microsoft Mark - English (United States)", "en-US", true, false},
+  };
+
+  ApplyProfileOverride(&p);
+
+  // clearcote: an explicit --fingerprint-gpu-vendor/-renderer overrides the seed-/profile-
+  // derived GPU (precedence: switch > imported profile > seed); WebGL getParameter reads these.
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd->HasSwitch(switches::kFingerprintGpuVendor))
+    p.webgl_vendor = cmd->GetSwitchValueASCII(switches::kFingerprintGpuVendor);
+  if (cmd->HasSwitch(switches::kFingerprintGpuRenderer))
+    p.webgl_renderer = cmd->GetSwitchValueASCII(switches::kFingerprintGpuRenderer);
+  return p;
+}
+
+const PersonaProfile& CurrentPersona() {
+  // Intentionally leaked process-lifetime singleton (no exit-time destructor),
+  // lazily initialized once per process.
+  static PersonaProfile* profile = nullptr;
+  static std::once_flag once;
+  std::call_once(once, [] {
+    profile = new PersonaProfile(DerivePersona(SeedFromCommandLine()));
+  });
+  return *profile;
+}
