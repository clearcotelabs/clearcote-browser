+namespace ungoogled {
+
+// A seed-derived, internally-COHERENT Windows browser persona.
+//
+// One uint64 seed (the existing --fingerprint switch) selects one believable
+// Windows machine: every field here is drawn TOGETHER so the combination is one
+// a real device actually shows -- e.g. hardware_concurrency and device_memory_gb
+// come from a single hardware tier (no 20-core CPU with 16 GB RAM), and the
+// WebGL renderer string matches the GPU vendor. Same seed => identical persona
+// across the browser process and every renderer in the session (the seed is
+// forwarded to all child processes), so no surface can contradict another.
+//
+// OS-family divergence is a supported, deliberate axis: --fingerprint-platform
+// selects windows/linux/macos/android, and DerivePersona() fixes up the OS-
+// specific fields (WebGL renderer, voices, media devices, and -- for android --
+// screen/DPR/touch/pointer/mobile) so the whole persona stays coherent for the
+// claimed OS. The struct defaults are Windows-shaped; other platforms override.
+struct COMPONENT_EXPORT(UNGOOGLED) PersonaProfile {
+  // SplitMix64-mixed seed, kept so downstream per-seed routines can mix it in.
+  uint64_t persona_seed = 0;
+
+  // ---- Identity ----
+  unsigned chrome_major_version = 149;
+  std::string chrome_full_version;  // e.g. "149.0.7827.114"
+
+  // ---- Hardware (one tier: cores <-> RAM correlated) ----
+  unsigned hardware_concurrency = 8;  // logical cores (navigator.hardwareConcurrency)
+  // True system RAM in GB (4..64). NOTE: navigator.deviceMemory is spec-clamped
+  // to a max of 8, so the getter reports min(8, this); the full value is kept
+  // for future Sec-CH-Device-Memory / side-channel coherence work.
+  float device_memory_gb = 8.0f;
+
+  // performance.memory.jsHeapSizeLimit. Real 64-bit desktop Chrome reports a
+  // fixed, non-round limit (~4192 MiB); an exact power of two looks synthetic.
+  // Constant on desktop (not host-RAM-scaled); overridable from a profile.
+  uint64_t js_heap_size_limit = 4395630592ULL;
+
+  // ---- Screen / window ----
+  int screen_width = 1920;
+  int screen_height = 1080;
+  int avail_screen_width = 1920;
+  int avail_screen_height = 1040;  // minus a realistic Windows taskbar
+  unsigned color_depth = 24;
+  double device_pixel_ratio = 1.0;
+
+  // ---- Mobile / touch / orientation (Android persona). Desktop-safe defaults
+  // so windows/linux/macos are entirely unaffected. ----
+  bool mobile = false;               // Mobile UA token + UA-CH mobile bit + web-prefs
+  int max_touch_points = 0;          // navigator.maxTouchPoints (5 on phones)
+  bool pointer_coarse = false;       // CSS (pointer/any-pointer:coarse) when true
+  bool hover_none = false;           // CSS (hover/any-hover:none) when true
+  const char* orientation_type = "landscape-primary";  // "portrait-primary" on phones
+  int orientation_angle = 0;         // screen.orientation.angle
+  bool dynamic_range_high = false;   // CSS (dynamic-range:high) / DeviceSupportsHDR
+  // UA-CH high-entropy identity for the Android persona, carried here so the
+  // reported model / platformVersion stay ATOMIC with the WebGL renderer chosen
+  // from the same device row. Empty on desktop personas.
+  std::string android_model;
+  std::string android_platform_version;
+
+  // ---- WebGL (Windows + ANGLE/D3D11) ----
+  std::string webgl_vendor;    // e.g. "Google Inc. (Intel)"
+  std::string webgl_renderer;  // ANGLE renderer string
+  // --disable-gpu-fingerprint: present the machine's REAL GPU (renderer/vendor strings, the
+  // getParameter table, and the supported-extension list) instead of this persona GPU, and
+  // skip the WebGL readback noise -- so the GPU identity matches the actually-rendered pixels.
+  bool webgl_real = false;
+  // Canonical Win11 + ANGLE parameter limits (for future getParameter wiring).
+  int webgl_max_texture_size = 16384;
+  int webgl_max_cube_map_texture_size = 16384;
+  int webgl_max_renderbuffer_size = 16384;
+  int webgl_max_viewport_dim = 32767;
+  int webgl_max_vertex_uniform_vectors = 4096;
+  int webgl_max_fragment_uniform_vectors = 1024;
+  int webgl_max_varying_vectors = 30;
+  int webgl_max_combined_texture_image_units = 32;
+
+  // ---- Audio (Windows WASAPI defaults) ----
+  float audio_sample_rate = 48000.0f;
+  double audio_base_latency = 0.01;
+  double audio_output_latency = 0.015;
+
+  // clearcote: WebGL2 getParameter limits (canonical ANGLE/D3D11, Win desktop).
+  int webgl_max_3d_texture_size = 2048;
+  int webgl_max_array_texture_layers = 2048;
+  int webgl_max_draw_buffers = 8;
+  int webgl_max_color_attachments = 8;
+  int webgl_max_samples = 8;
+  int webgl_max_vertex_uniform_blocks = 14;
+  int webgl_max_fragment_uniform_blocks = 14;
+  int webgl_max_combined_uniform_blocks = 24;
+  int webgl_max_uniform_buffer_bindings = 24;
+  float webgl_max_texture_lod_bias = 2.0f;
+  int webgl_max_vertex_uniform_components = 16384;
+  int webgl_max_fragment_uniform_components = 4096;
+
+  // speechSynthesis.getVoices(): a real Windows Chrome exposes SAPI voices;
+  // an empty list is a headless tell. Default-populated in DerivePersona,
+  // overridable from an imported profile.
+  struct Voice {
+    std::string voice_uri;
+    std::string name;
+    std::string lang;
+    bool local_service = true;
+    bool is_default = false;
+  };
+  std::vector<Voice> voices;
+
+  // measureText font enumeration: the family names reported present. Default-
+  // empty (the canonical platform set is used); an imported profile fills it.
+  std::vector<std::string> fonts;
+
+  // ---- WebGL full getParameter table (driver/GPU-dependent; defaults are
+  // common Intel-class desktop values; overridable from an imported profile) ----
+  int webgl_aliased_line_width_range_min = 1;
+  int webgl_aliased_line_width_range_max = 1;
+  int webgl_aliased_point_size_range_min = 1;
+  int webgl_aliased_point_size_range_max = 1024;
+  int webgl_red_bits = 8;
+  int webgl_green_bits = 8;
+  int webgl_blue_bits = 8;
+  int webgl_alpha_bits = 8;
+  int webgl_depth_bits = 24;
+  int webgl_stencil_bits = 8;
+  int webgl_subpixel_bits = 4;
+  int webgl_sample_buffers = 1;
+  int webgl_samples = 4;
+  float webgl_max_texture_max_anisotropy = 16.0f;
+  // getSupportedExtensions list (varies by driver); empty => report the real set.
+  std::vector<std::string> webgl_extensions;
+
+  // CSS @media color-gamut: "srgb" (default), "p3", or "rec2020".
+  std::string css_color_gamut = "srgb";
+
+  // ---- WebGPU adapter.limits (GPUSupportedLimits). Keys are the JS limit
+  // names (e.g. "maxTextureDimension2D"); values override the host GPU's
+  // reported limits so they stay coherent with the spoofed WebGL GPU. Filled
+  // with a canonical desktop table by DerivePersona; an imported profile's
+  // webgpu.limits overrides individual entries.
+  std::map<std::string, uint64_t> webgpu_limits;
+
+  // ---- WebGPU adapter identity (GPUAdapterInfo.vendor / .architecture),
+  // kept coherent with the spoofed WebGL GPU so navigator.gpu can't contradict
+  // the WebGL UNMASKED vendor. Lowercase per the WebGPU spec ("intel"/"nvidia"/
+  // "amd"; "gen-12-lp"/"ampere"/"rdna2"). Derived from the final webgl_vendor in
+  // DerivePersona; an imported profile (webgpu.vendor/.architecture) or
+  // --fingerprint-webgpu-vendor/-architecture overrides.
+  std::string webgpu_vendor;
+  std::string webgpu_architecture;
+
+  // ---- MediaCapabilities.decodingInfo() per codec family. Key is the codec
+  // family ("h264","vp8","vp9","av1","hevc"); the triple overrides the host's
+  // real {supported, smooth, powerEfficient} so playback support reads coherently
+  // with the spoofed WebGL/WebGPU GPU tier regardless of the build host's actual
+  // decode hardware. Default-populated by DerivePersona; an imported profile's
+  // mediaCapabilities/codecs dict overrides individual entries.
+  struct MediaCodecSupport {
+    bool supported = true;
+    bool smooth = true;
+    bool power_efficient = true;
+  };
+  std::map<std::string, MediaCodecSupport> media_codecs;
+
+  // ---- enumerateDevices() persona device list. Real Windows always exposes
+  // at least one audioinput + audiooutput (empty id/label pre-permission); an
+  // empty list reads as a headless server -- a tell. Each entry carries a RAW
+  // device_id/group_id (stable, seed-derived); the browser-process per-origin
+  // HMAC salt (TranslateMediaDeviceInfo) hashes them per site and blanks labels
+  // pre-grant, so we store raw strings + plain labels here. The literal
+  // "default"/"communications" ids pass through unhashed (Chrome's convention).
+  struct MediaDevice {
+    std::string kind;  // "audioinput" | "audiooutput" | "videoinput"
+    std::string label;
+    std::string device_id;
+    std::string group_id;
+  };
+  std::vector<MediaDevice> media_devices;
+};
+
+// Derives a coherent Windows persona from a seed. Same seed => same persona.
+// Pools are weighted to common Chrome-on-Windows distributions; the hardware
+// tier keeps (cores, RAM) to combinations that exist in the wild.
+COMPONENT_EXPORT(UNGOOGLED) PersonaProfile DerivePersona(uint64_t seed);
+
+// Process-wide singleton persona for this session. The first call reads the
+// --fingerprint switch (numeric, or FNV-1a-hashed if non-numeric -- matching
+// the per-site seed parse so browser + renderers agree) and derives the
+// persona; later calls return the same one. Thread-safe (std::call_once).
+COMPONENT_EXPORT(UNGOOGLED) const PersonaProfile& CurrentPersona();
+
+}  // namespace ungoogled
