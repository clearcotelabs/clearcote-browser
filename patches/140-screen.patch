 namespace blink {
 
+namespace {
+// clearcote: when --fingerprint is set, screen.* report the coherent
+// session persona's display instead of the host's real screen.
+bool PersonaScreenActive() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  return cmd && cmd->HasSwitch(switches::kFingerprint);
+}
+}  // namespace
