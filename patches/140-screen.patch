 float ScreenDetailed::devicePixelRatio() const {
   if (!DomWindow())
     return 0.f;
+  if (PersonaScreenActive()) {
+    // persona: match window.devicePixelRatio and the media-values DPR so the
+    // per-screen DPR cannot contradict the rest of the page.
+    return static_cast<float>(ungoogled::CurrentPersona().device_pixel_ratio);
+  }
   return GetScreenInfo().device_scale_factor;
 }
 
 String ScreenDetailed::label() const {
   if (!DomWindow())
     return String();
+  if (PersonaScreenActive())
+    return String();  // persona: empty label (real Chrome reports an empty
+                      // label absent window-management consent), hides the
+                      // host display's OS/connector name
   return String::FromUtf8(GetScreenInfo().label);
 }
 
