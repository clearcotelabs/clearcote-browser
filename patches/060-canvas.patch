+// canvas-bridge: lazily create the server-side surface for this 2D context and
+// return its stable id, so recorded ops and the readback target one canvas.
+uint32_t EnsureBridgeCanvas(blink::canvas_bridge::CanvasBridgeClient* bridge,
+                            uint32_t& id, int width, int height) {
+  if (id == 0) {
+    id = bridge->AllocateCanvasId();
+    blink::canvas_bridge::CreateCanvas2DMessage create;
+    create.canvas_id = id;
+    create.width = static_cast<uint32_t>(width < 0 ? 0 : width);
+    create.height = static_cast<uint32_t>(height < 0 ? 0 : height);
+    create.opaque = false;
+    bridge->Send(blink::canvas_bridge::Encode(create));
+  }
+  return id;
+}
+
+}  // namespace
+
+bool BaseRenderingContext2D::BridgeAllowedForThisContext() {
+  if (!bridge_policy_checked_) {
+    bridge_policy_checked_ = true;
+    bridge_policy_allowed_ = false;
+    if (auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get()) {
+      std::string etld1;
+      if (auto* ec = GetTopExecutionContext(); ec && ec->GetSecurityOrigin()) {
+        etld1 = ec->GetSecurityOrigin()->RegistrableDomain().Utf8();
+      }
+      bridge_policy_allowed_ = cb->BridgeEnabledForOrigin(etld1);
+    }
+  }
+  return bridge_policy_allowed_;
+}
+
+void BaseRenderingContext2D::RecordBridgeOp(
+    uint32_t op, const std::string& str, const std::vector<double>& args) {
+  auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!cb || !cb->Connected() || !BridgeAllowedForThisContext())
+    return;
+  blink::canvas_bridge::Canvas2DOpMessage m;
+  m.canvas_id = EnsureBridgeCanvas(cb, bridge_canvas_id_, Width(), Height());
+  m.op = op;
+  m.str_arg = str;
+  m.args = args;
+  cb->Send(blink::canvas_bridge::Encode(m));
+  // Tier 1: a draw op changes the rendered surface -> bump version + prefetch.
+  using CbOp = blink::canvas_bridge::Canvas2DOp;
+  switch (static_cast<CbOp>(op)) {
+    case CbOp::kFill:
+    case CbOp::kStroke:
+    case CbOp::kFillRect:
+    case CbOp::kStrokeRect:
+    case CbOp::kClearRect:
+    case CbOp::kFillText:
+    case CbOp::kStrokeText:
+      cb->BumpVersion(m.canvas_id);
+      cb->MaybePrefetch(m.canvas_id, static_cast<uint32_t>(Width()),
+                        static_cast<uint32_t>(Height()));
+      break;
+    default:
+      break;
+  }
+}
+
+bool BaseRenderingContext2D::ReadBridgePixels(std::vector<uint8_t>* out,
+                                              int width, int height) {
+  auto* cb = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!cb || !cb->Connected() || bridge_canvas_id_ == 0 ||
+      !BridgeAllowedForThisContext())
+    return false;
+  std::optional<std::vector<uint8_t>> px =
+      cb->GetImageDataCacheFirst(bridge_canvas_id_, 0, 0, width, height);
+  if (!px || px->size() != static_cast<size_t>(width) * height * 4)
+    return false;
+  *out = std::move(*px);
+  return true;
+}
