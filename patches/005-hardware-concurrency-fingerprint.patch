--- a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
+++ b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
@@ -4,11 +4,40 @@
 
 #include "third_party/blink/renderer/core/frame/navigator_concurrent_hardware.h"
 
+#include <cstdint>
+#include <functional>
+#include <string>
+
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
 #include "base/system/sys_info.h"
+#include "components/ungoogled/ungoogled_switches.h"
 
 namespace blink {
 
 unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  // The per-site, seed-derived hardware concurrency is computed by
+  // NavigatorBase::hardwareConcurrency(), which has the ExecutionContext (and
+  // thus the security origin / eTLD+1) required for per-site farbling. This
+  // mixin provides:
+  //   1. the explicit --fingerprint-hardware-concurrency=N override, and
+  //   2. the unfarbled fallback: the real number of logical processors.
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+
+  // Non-throwing parse: Chromium is built with exceptions disabled, so a
+  // std::stoul() on a non-numeric value would crash the renderer
+  // (CPP_EH_EXCEPTION). Fall through to the default on bad/zero input.
+  if (command_line->HasSwitch(switches::kFingerprintHardwareConcurrency)) {
+    std::string value = command_line->GetSwitchValueASCII(
+        switches::kFingerprintHardwareConcurrency);
+    unsigned custom_concurrency = 0;
+    if (base::StringToUint(value, &custom_concurrency) &&
+        custom_concurrency > 0) {
+      return custom_concurrency;
+    }
+  }
+
   return static_cast<unsigned>(base::SysInfo::NumberOfProcessors());
 }
 
