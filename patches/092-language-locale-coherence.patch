+namespace {
+// clearcote: align the process ICU default locale + flush V8's cached Intl locale so
+// Intl.DateTimeFormat()/Number.toLocaleString() and friends follow the persona's primary
+// Accept-Language tag (navigator.languages.front()). Without this the renderer's Intl locale
+// stays at the build default (en-US) while navigator.languages reports e.g. de-DE -- a
+// locale-coherence contradiction that stock Chrome does not have (it derives the renderer ICU
+// locale from --lang). icu::Locale::setDefault is process-global and NOT thread-safe, so only
+// touch it on the main thread; worker scopes read the value the main thread already aligned.
+void AlignIcuDefaultLocale(ExecutionContext* context,
+                           const Vector<String>& languages) {
+  if (languages.empty() || !IsMainThread())
+    return;
+  base::i18n::SetICUDefaultLocale(languages.front().Utf8());
+  if (context && context->GetIsolate())
+    context->GetIsolate()->LocaleConfigurationChangeNotification();
+}
+}  // namespace
