 namespace webrtc {
+
+// clearcoat: WebRTC IP mock storage (process-global; one proxy per process).
+namespace {
+Mutex& ClearcoatForcedIpMutex() {
+  static Mutex* m = new Mutex();
+  return *m;
+}
+std::optional<IPAddress>& ClearcoatForcedIpStore() {
+  static std::optional<IPAddress>* ip = new std::optional<IPAddress>();
+  return *ip;
+}
+}  // namespace
+
+void SetForcedWebRtcSrflxIP(absl::string_view ip) {
+  IPAddress parsed;
+  if (IPFromString(ip, &parsed)) {
+    MutexLock lock(&ClearcoatForcedIpMutex());
+    ClearcoatForcedIpStore() = parsed;
+  }
+}
+bool HasForcedWebRtcSrflxIP() {
+  MutexLock lock(&ClearcoatForcedIpMutex());
+  return ClearcoatForcedIpStore().has_value();
+}
+IPAddress ForcedWebRtcSrflxIP() {
+  MutexLock lock(&ClearcoatForcedIpMutex());
+  return ClearcoatForcedIpStore().value_or(IPAddress());
+}
