+namespace {
+
+// clearcote persona: Chromium applies Windows drive-letter fixups
+// ("C:/foo" -> "file:///C:/foo") only in builds where WIN32 is defined
+// (url/url_util.cc DoCanonicalize, url/url_canon_relative.cc DoIsRelativeUrl).
+// Fingerprint scripts read new URL("C:/").protocol to infer the OS
+// (Windows => "file:", Linux/macOS => "c:"), so the behaviour must follow the
+// PERSONA rather than the host build: a Windows persona served from a Linux
+// box has to say "file:", and a Linux persona must never say "file:".
+//
+// The persona platform is resolved exactly the way Navigator::platform()
+// (core/frame/navigator.cc) and GetReducedNavigatorPlatform()
+// (core/execution_context/navigator_base.cc) resolve it: the
+// --fingerprint-platform switch when it carries a recognized value, otherwise
+// the host build. Keeping all three in lockstep is the point -- navigator.
+// platform and new URL("C:/").protocol must not be able to contradict.
+//
+// Cached in a function-local static: DOMURL is constructed on every
+// `new URL(...)` and the command line is fixed for the process lifetime.
+bool IsWindowsPersona() {
+  static const bool kIsWindowsPersona = [] {
+    const base::CommandLine* command_line =
+        base::CommandLine::ForCurrentProcess();
+    if (command_line->HasSwitch(switches::kFingerprintPlatform)) {
+      const std::string persona_platform = base::ToLowerASCII(
+          command_line->GetSwitchValueASCII(switches::kFingerprintPlatform));
+      if (persona_platform == "windows")
+        return true;
+      if (persona_platform == "linux" || persona_platform == "macos" ||
+          persona_platform == "android")
+        return false;
+      // Unrecognized value: fall through to the host build, which is what
+      // Navigator::platform() does for the same input.
+    }
+#if BUILDFLAG(IS_WIN)
+    return true;
+#else
+    return false;
+#endif
+  }();
+  return kIsWindowsPersona;
+}
+
+// Applied only under a Windows persona (see above). The match window is
+// minimal (single ASCII letter, ':', then '/' or backslash 0x5C) so legitimate
+// single-letter scheme URLs (go:foo, ws:bar) are never rewritten.
+String MaybeRewriteDriveLetter(const String& url) {
+  if (!IsWindowsPersona())
+    return url;
+  if (url.length() < 3)
+    return url;
+  UChar c0 = url[0];
+  UChar c1 = url[1];
+  UChar c2 = url[2];
+  if (!((c0 >= 'A' && c0 <= 'Z') || (c0 >= 'a' && c0 <= 'z')))
+    return url;
+  if (c1 != ':')
+    return url;
+  if (c2 != '/' && c2 != 0x5C)
+    return url;
+  return "file:///" + url;
+}
+
+}  // namespace
