+// Copyright 2024 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef NET_SSL_NETWORK_PERSONA_H_
+#define NET_SSL_NETWORK_PERSONA_H_
+
+#include "net/base/net_export.h"
+
+namespace net {
+
+// A "network persona" makes the TLS ClientHello's version-variant fields match
+// a claimed Chromium major, instead of the major this build was compiled from.
+// It is driven by the launch switch `--fingerprint-tls-profile=<value>`, read
+// in the network-service process (where net/ssl runs).
+//
+// This is coherence-first, not arbitrary spoofing: it only swaps the fields
+// that genuinely differ between real Chromium majors (the post-quantum
+// key-share group, the ALPS codepoint, ECH GREASE presence). The deterministic
+// envelope (cipher list, version bounds, signature algorithms, ALPN) and the
+// per-connection extension permutation are left exactly as stock Chromium.
+//
+// Value grammar (Phase 1):
+//   "chrome-<major>"     e.g. "chrome-149", "chrome-120" -> version override
+//   absent / "" / "off" / "native" / "auto" / "match-persona" -> NO override
+// A claimed major equal to this build's own Chromium major is also a no-op
+// (byte-identical to stock). `auto` / `match-persona` are resolved SDK-side to
+// a concrete `chrome-<major>`; the engine treats any unrecognized token as a
+// no-op and never breaks the handshake.
+struct NET_EXPORT NetworkPersonaPlan {
+  // How to shape the post-quantum key-share group for the claimed major.
+  enum PqMode {
+    // The claimed major uses the same PQ group as this build (X25519MLKEM768).
+    // No group/key_share override is needed; stock emits the correct bytes.
+    kNative,
+    // The claimed major (~124..130) predates ML-KEM: use X25519Kyber768Draft00.
+    kKyber,
+    // The claimed major (<124) predates default-on PQ: emit no PQ group at all
+    // (classic groups + a classic key_share only).
+    kNone,
+  };
+
+  // True when a concrete, non-native `chrome-<major>` override was requested.
+  // When false, callers MUST leave the stock ClientHello untouched.
+  bool active = false;
+
+  // The claimed Chromium major (only meaningful when `active` is true).
+  int major = 0;
+
+  // The post-quantum shaping to apply (only meaningful when `active` is true).
+  PqMode pq = kNative;
+
+  // Whether the claimed major sends the ALPS extension under the new codepoint
+  // (0x44CD, ~131+) rather than the old one (0x4469, older majors).
+  bool alps_new_codepoint = true;
+
+  // Whether the claimed major emits an ECH GREASE extension (present ~149,
+  // absent in older majors).
+  bool ech_grease = true;
+};
+
+// Computes the network persona plan from the current process command line
+// (`--fingerprint-tls-profile`). Cheap and side-effect free; safe to call once
+// per socket. Returns an inactive plan when no override is requested.
+NET_EXPORT NetworkPersonaPlan ComputeNetworkPersona();
+
+}  // namespace net
+
+#endif  // NET_SSL_NETWORK_PERSONA_H_
