+// Copyright 2024 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "net/ssl/network_persona.h"
+
+#include <string>
+#include <string_view>
+
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/version_info/version_info.h"
+
+namespace net {
+
+namespace {
+
+// Literal switch name. We intentionally use the string literal rather than
+// depending on //components/ungoogled so this low-level net target stays free
+// of that dependency. Must match `switches::kFingerprintTlsProfile`.
+constexpr char kFingerprintTlsProfileSwitch[] = "fingerprint-tls-profile";
+
+// Post-quantum key-share default-on boundaries in real Chrome:
+//   X25519Kyber768Draft00 (0x6399): default-on ~Chrome 124.
+//   X25519MLKEM768 (0x11EC): switched to the final group ~Chrome 131.
+// So a claimed major in [124, 131) uses Kyber; >= 131 uses ML-KEM;
+// < 124 ships no post-quantum group at all.
+constexpr int kKyberDefaultOnMajor = 124;
+constexpr int kMlkemSwitchMajor = 131;
+
+// ALPS moved to the new codepoint (0x44CD) around the same milestone as the
+// ML-KEM switch; older majors used the old codepoint (0x4469).
+constexpr int kNewAlpsCodepointMajor = 131;
+
+// ECH GREASE has been present since ECH shipped (~Chrome 117), i.e. across the
+// entire modeled range (120..149). It does not vary here, so it is never
+// suppressed in Phase 1 (a boundary of 0 keeps `ech_grease` always true).
+constexpr int kEchGreaseMajor = 0;
+
+// Parses "chrome-<major>" into `major`. Returns true on success. The brand
+// token is header-only and does not change the TLS envelope, but Phase 1 only
+// ever emits "chrome-<major>"; accept exactly that shape here.
+bool ParseChromeMajor(std::string_view value, int* major) {
+  constexpr std::string_view kPrefix = "chrome-";
+  if (value.size() <= kPrefix.size() ||
+      value.substr(0, kPrefix.size()) != kPrefix) {
+    return false;
+  }
+  int parsed = 0;
+  if (!base::StringToInt(value.substr(kPrefix.size()), &parsed) ||
+      parsed <= 0) {
+    return false;
+  }
+  *major = parsed;
+  return true;
+}
+
+}  // namespace
+
+NetworkPersonaPlan ComputeNetworkPersona() {
+  NetworkPersonaPlan plan;
+
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line ||
+      !command_line->HasSwitch(kFingerprintTlsProfileSwitch)) {
+    return plan;  // inactive
+  }
+
+  const std::string value =
+      command_line->GetSwitchValueASCII(kFingerprintTlsProfileSwitch);
+
+  // Explicit no-op tokens. `auto` / `match-persona` are resolved SDK-side to a
+  // concrete `chrome-<major>`; if one leaks through to the engine, treat it as
+  // a no-op rather than guessing.
+  if (value.empty() || value == "off" || value == "native" ||
+      value == "auto" || value == "match-persona") {
+    return plan;  // inactive
+  }
+
+  int claimed_major = 0;
+  if (!ParseChromeMajor(value, &claimed_major)) {
+    // Unrecognized value (e.g. a raw-JA3 escape hatch, a Phase 4 concern):
+    // never break the handshake. Fall back to native.
+    return plan;  // inactive
+  }
+
+  // A claimed major equal to this build's own major is a no-op: stock already
+  // emits exactly the right bytes.
+  const int build_major = version_info::GetMajorVersionNumberAsInt();
+  if (claimed_major == build_major) {
+    return plan;  // inactive
+  }
+
+  plan.active = true;
+  plan.major = claimed_major;
+
+  if (claimed_major >= kMlkemSwitchMajor) {
+    // ML-KEM era: same PQ group as this build. No group/key_share delta needed;
+    // the plan is "active" only for the ALPS/ECH deltas (which for >= 131 also
+    // match this build, making the net effect byte-identical to stock).
+    plan.pq = NetworkPersonaPlan::kNative;
+  } else if (claimed_major >= kKyberDefaultOnMajor) {
+    plan.pq = NetworkPersonaPlan::kKyber;
+  } else {
+    plan.pq = NetworkPersonaPlan::kNone;
+  }
+
+  plan.alps_new_codepoint = (claimed_major >= kNewAlpsCodepointMajor);
+  plan.ech_grease = (claimed_major >= kEchGreaseMajor);
+
+  return plan;
+}
+
+}  // namespace net
