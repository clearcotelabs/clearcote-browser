+void Document::EnsureNoiseFactorsInitialized() {
+  if (noise_factor_initialized_)
+    return;
+  noise_factor_initialized_ = true;
+
+  // Gate on the global --fingerprint switch (preserved from the original
+  // adryfish patch). When absent, the noise factors keep their identity
+  // defaults (1) and clientRects are left unperturbed.
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kFingerprint))
+    return;
+
+  // Derive the per-site (eTLD+1) farbling seed. The origin is available now
+  // because initialization is deferred until first getter access.
+  std::string registrable_domain;
+  if (ExecutionContext* context = GetExecutionContext()) {
+    if (const SecurityOrigin* origin = context->GetSecurityOrigin())
+      registrable_domain = origin->RegistrableDomain().Utf8();
+  }
+  uint64_t seed = ungoogled::GetFarbleSeed64(registrable_domain);
+  std::string seed_str = base::NumberToString(seed);
+
+  // Use different combined strings for x and y.
+  std::string combined_x = seed_str + "offset_x";
+  std::string combined_y = seed_str + "offset_y";
+
+  uint32_t hash_val_x = std::hash<std::string>{}(combined_x);
+  uint32_t hash_val_y = std::hash<std::string>{}(combined_y);
+
+  // Map to [-0.5, 0.5] range.
+  double norm_x = (hash_val_x & 0xFFFFFFFF) / 4294967295.0 - 0.5;
+  double norm_y = (hash_val_y & 0xFFFFFFFF) / 4294967295.0 - 0.5;
+
+  // Compute a very small offset: +/- 0.001 pixels.
+  noise_factor_x_ = norm_x * 0.002;
+  noise_factor_y_ = norm_y * 0.002;
+}
+
 double Document::GetNoiseFactorX() {
+  EnsureNoiseFactorsInitialized();
   return noise_factor_x_;
 }
 
 double Document::GetNoiseFactorY() {
+  EnsureNoiseFactorsInitialized();
   return noise_factor_y_;
 }
 
