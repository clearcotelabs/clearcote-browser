+// static
+CanvasBridgeClient* CanvasBridgeClient::Get() {
+  static CanvasBridgeClient* instance = []() -> CanvasBridgeClient* {
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (!cmd->HasSwitch(switches::kCanvasBridgeUrl))
+      return nullptr;
+    std::string url = cmd->GetSwitchValueASCII(switches::kCanvasBridgeUrl);
+    std::string host, path;
+    int port = 0;
+    if (!ParseUrl(url, &host, &port, &path)) {
+      LOG(ERROR) << "canvas-bridge: malformed --canvas-bridge-url";
+      return nullptr;
+    }
+    std::string auth = cmd->GetSwitchValueASCII(switches::kCanvasBridgeAuth);
+    return new CanvasBridgeClient(std::move(host), port, std::move(path),
+                                  std::move(auth));
+  }();
+  return instance;
+}
+
+CanvasBridgeClient::CanvasBridgeClient(std::string host,
+                                       int port,
+                                       std::string path,
+                                       std::string auth)
+    : host_(std::move(host)),
+      port_(port),
+      path_(std::move(path)),
+      auth_(std::move(auth)) {
+  // Dedicated, detached I/O thread runs connect + read loop for the process
+  // lifetime. The singleton is intentionally leaked, so the thread is never
+  // joined.
+  base::PlatformThread::CreateNonJoinable(0, this);
+}
+
+CanvasBridgeClient::~CanvasBridgeClient() = default;
+
+bool CanvasBridgeClient::Connected() {
+  base::AutoLock lock(state_lock_);
+  return connected_;
+}
+
+uint32_t CanvasBridgeClient::AllocateCanvasId() {
+  base::AutoLock lock(id_lock_);
+  return next_canvas_id_++;
+}
+
+void CanvasBridgeClient::ThreadMain() {
+  base::PlatformThread::SetName("CanvasBridge");
+  if (!Connect()) {
+    LOG(ERROR) << "canvas-bridge: connect failed; rendering stays local";
+    return;
+  }
+  {
+    base::AutoLock lock(state_lock_);
+    connected_ = true;
+  }
+  VLOG(1) << "canvas-bridge: connected to " << host_ << ":" << port_;
+  ReadLoop();
+  {
+    base::AutoLock lock(state_lock_);
+    connected_ = false;
+  }
+}
+
+bool CanvasBridgeClient::Connect() {
+#if BUILDFLAG(IS_WIN)
+  EnsureWinsock();
+#endif
+  addrinfo hints = {};
+  hints.ai_family = AF_UNSPEC;
+  hints.ai_socktype = SOCK_STREAM;
+  addrinfo* result = nullptr;
+  std::string port_str = base::NumberToString(port_);
+  if (::getaddrinfo(host_.c_str(), port_str.c_str(), &hints, &result) != 0)
+    return false;
+
+  uintptr_t sock = kInvalidSocket;
+  for (addrinfo* ai = result; ai; ai = ai->ai_next) {
+    uintptr_t s = static_cast<uintptr_t>(
+        ::socket(ai->ai_family, ai->ai_socktype, ai->ai_protocol));
+    if (s == kInvalidSocket)
+      continue;
+    if (::connect(static_cast<
+#if BUILDFLAG(IS_WIN)
+                      SOCKET
+#else
+                      int
+#endif
+                      >(s),
+                  ai->ai_addr, static_cast<int>(ai->ai_addrlen)) == 0) {
+      sock = s;
+      break;
+    }
+    CloseSocketHandle(s);
+  }
+  ::freeaddrinfo(result);
+  if (sock == kInvalidSocket)
+    return false;
+  socket_ = sock;
+
+  // RFC 6455 client handshake.
+  uint8_t key_bytes[16];
+  base::RandBytes(key_bytes);
+  std::string key = base::Base64Encode(key_bytes);
+  std::string req =
+      "GET " + path_ + " HTTP/1.1\r\n" + "Host: " + host_ + ":" +
+      port_str + "\r\n" + "Upgrade: websocket\r\n" +
+      "Connection: Upgrade\r\n" + "Sec-WebSocket-Version: 13\r\n" +
+      "Sec-WebSocket-Key: " + key + "\r\n";
+  if (!auth_.empty()) {
+    req += "Authorization: Basic " + base::Base64Encode(base::as_byte_span(auth_)) +
+           "\r\n";
+  }
+  req += "\r\n";
+  if (!WriteExact(req.data(), req.size())) {
+    CloseSocket();
+    return false;
+  }
+
+  std::string resp;
+  char c = 0;
+  while (resp.size() < 8192) {
+    if (!ReadExact(&c, 1)) {
+      CloseSocket();
+      return false;
+    }
+    resp.push_back(c);
+    if (resp.size() >= 4 &&
+        resp.compare(resp.size() - 4, 4, "\r\n\r\n") == 0)
+      break;
+  }
+  if (resp.find(" 101 ") == std::string::npos) {
+    CloseSocket();
+    return false;
+  }
+
+  HelloMessage hello;
+  hello.persona_seed = ungoogled::CurrentPersona().persona_seed;
+  hello.client_version = "clearcote-canvas-bridge/1";
+  return WriteWebSocketFrame(Encode(hello));
+}
+
+void CanvasBridgeClient::ReadLoop() {
+  std::vector<uint8_t> frame;
+  while (ReadWebSocketFrame(&frame))
+    Dispatch(frame);
+  CloseSocket();
+}
+
+void CanvasBridgeClient::Dispatch(base::span<const uint8_t> frame) {
+  switch (PeekType(frame)) {
+    case MessageType::kImageData: {
+      std::optional<ImageDataMessage> msg = DecodeImageData(frame);
+      if (!msg)
+        return;
+      base::AutoLock lock(pending_lock_);
+      auto it = pending_.find(msg->canvas_id);
+      if (it != pending_.end()) {
+        it->second->pixels = std::move(msg->pixels);
+        it->second->event.Signal();
+      }
+      return;
+    }
+    case MessageType::kWelcome: {
+      std::optional<WelcomeMessage> msg = DecodeWelcome(frame);
+      if (msg)
+        VLOG(1) << "canvas-bridge: server gpu=" << msg->gpu_renderer;
+      return;
+    }
+    default:
+      return;
+  }
+}
+
+std::optional<std::vector<uint8_t>> CanvasBridgeClient::RequestImageData(
+    uint32_t canvas_id,
+    int32_t x,
+    int32_t y,
+    uint32_t width,
+    uint32_t height) {
+  if (!Connected())
+    return std::nullopt;
+
+  PendingReadback pending;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_[canvas_id] = &pending;
+  }
+
+  GetImageDataMessage req;
+  req.canvas_id = canvas_id;
+  req.x = x;
+  req.y = y;
+  req.width = width;
+  req.height = height;
+  Send(Encode(req));
+
+  pending.event.TimedWait(base::Seconds(5));
+
+  std::optional<std::vector<uint8_t>> result;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_.erase(canvas_id);
+    result = std::move(pending.pixels);
+  }
+  return result;
+}
+
+std::optional<std::vector<uint8_t>> CanvasBridgeClient::RequestTextMetrics(
+    uint32_t canvas_id, const std::string& text) {
+  if (!Connected())
+    return std::nullopt;
+  PendingReadback pending;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_[canvas_id] = &pending;
+  }
+  MeasureTextMessage req;
+  req.canvas_id = canvas_id;
+  req.text = text;
+  Send(Encode(req));
+  pending.event.TimedWait(base::Seconds(5));
+  std::optional<std::vector<uint8_t>> result;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_.erase(canvas_id);
+    result = std::move(pending.pixels);
+  }
+  return result;
+}
+
+bool CanvasBridgeClient::Send(base::span<const uint8_t> frame) {
+  if (!Connected())
+    return false;
+  return WriteWebSocketFrame(frame);
+}
+
+bool CanvasBridgeClient::WriteWebSocketFrame(base::span<const uint8_t> payload) {
+  std::vector<uint8_t> header;
+  header.push_back(0x82);  // FIN + binary opcode.
+  const size_t len = payload.size();
+  if (len < 126) {
+    header.push_back(static_cast<uint8_t>(0x80 | len));
+  } else if (len < 65536) {
+    header.push_back(0x80 | 126);
+    header.push_back(static_cast<uint8_t>((len >> 8) & 0xFF));
+    header.push_back(static_cast<uint8_t>(len & 0xFF));
+  } else {
+    header.push_back(0x80 | 127);
+    for (int i = 7; i >= 0; --i)
+      header.push_back(static_cast<uint8_t>((len >> (8 * i)) & 0xFF));
+  }
+  uint8_t mask[4];
+  base::RandBytes(mask);
+  header.insert(header.end(), mask, mask + 4);
+
+  std::vector<uint8_t> masked(payload.begin(), payload.end());
+  for (size_t i = 0; i < masked.size(); ++i)
+    masked[i] ^= mask[i % 4];
+
+  base::AutoLock lock(write_lock_);
+  return WriteExact(header.data(), header.size()) &&
+         WriteExact(masked.data(), masked.size());
+}
+
+bool CanvasBridgeClient::ReadWebSocketFrame(std::vector<uint8_t>* out) {
+  for (;;) {
+    uint8_t h[2];
+    if (!ReadExact(h, 2))
+      return false;
+    const uint8_t opcode = h[0] & 0x0F;
+    const bool masked = (h[1] & 0x80) != 0;
+    uint64_t len = h[1] & 0x7F;
+    if (len == 126) {
+      uint8_t e[2];
+      if (!ReadExact(e, 2))
+        return false;
+      len = (uint64_t{e[0]} << 8) | e[1];
+    } else if (len == 127) {
+      uint8_t e[8];
+      if (!ReadExact(e, 8))
+        return false;
+      len = 0;
+      for (int i = 0; i < 8; ++i)
+        len = (len << 8) | e[i];
+    }
+    uint8_t mask[4] = {0, 0, 0, 0};
+    if (masked && !ReadExact(mask, 4))
+      return false;
+
+    std::vector<uint8_t> payload(len);
+    if (len && !ReadExact(payload.data(), payload.size()))
+      return false;
+    if (masked) {
+      for (size_t i = 0; i < payload.size(); ++i)
+        payload[i] ^= mask[i % 4];
+    }
+
+    if (opcode == 0x8)  // close
+      return false;
+    if (opcode == 0x9 || opcode == 0xA)  // ping/pong: ignore
+      continue;
+    *out = std::move(payload);
+    return true;
+  }
+}
+
+bool CanvasBridgeClient::ReadExact(void* buf, size_t n) {
+  uint8_t* p = static_cast<uint8_t*>(buf);
+  size_t got = 0;
+  while (got < n) {
+#if BUILDFLAG(IS_WIN)
+    int r = ::recv(static_cast<SOCKET>(socket_),
+                   reinterpret_cast<char*>(p + got),
+                   static_cast<int>(n - got), 0);
+#else
+    ssize_t r = ::recv(static_cast<int>(socket_), p + got, n - got, 0);
+#endif
+    if (r <= 0)
+      return false;
+    got += static_cast<size_t>(r);
+  }
+  return true;
+}
+
+bool CanvasBridgeClient::WriteExact(const void* buf, size_t n) {
+  const uint8_t* p = static_cast<const uint8_t*>(buf);
+  size_t sent = 0;
+  while (sent < n) {
+#if BUILDFLAG(IS_WIN)
+    int r = ::send(static_cast<SOCKET>(socket_),
+                   reinterpret_cast<const char*>(p + sent),
+                   static_cast<int>(n - sent), 0);
+#else
+    ssize_t r = ::send(static_cast<int>(socket_), p + sent, n - sent, 0);
+#endif
+    if (r <= 0)
+      return false;
+    sent += static_cast<size_t>(r);
+  }
+  return true;
+}
+
+void CanvasBridgeClient::CloseSocket() {
+  if (socket_ == kInvalidSocket)
+    return;
+  CloseSocketHandle(socket_);
+  socket_ = kInvalidSocket;
+}
