+};
+
+struct GetImageDataMessage {
+  uint32_t canvas_id = 0;
+  int32_t x = 0;
+  int32_t y = 0;
+  uint32_t width = 0;
+  uint32_t height = 0;
+};
+
+struct ImageDataMessage {
+  uint32_t canvas_id = 0;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  std::vector<uint8_t> pixels;  // RGBA8, width*height*4 bytes
+};
+
+// Leading message type, or kUnknown if the frame is too short.
+MessageType PeekType(base::span<const uint8_t> frame);
