+// Copyright 2026 The Clearcote Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license.
+//
+// CanvasBridgeClient — a renderer-process singleton that forwards canvas/WebGL
+// readbacks to a remote real-GPU render host and returns its authentic pixels,
+// so a spoofed GPU persona stays coherent with what the page actually hashes.
+//
+// Active only when --canvas-bridge-url is set; otherwise Get() returns nullptr
+// and all rendering stays fully local. The connection is a raw TCP + RFC 6455
+// WebSocket on a dedicated thread, so the renderer must run unsandboxed
+// (--no-sandbox) — the documented requirement for the bridge.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
+#define THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
+
+#include <cstdint>
+#include <map>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/containers/span.h"
+#include "base/synchronization/lock.h"
+#include "base/synchronization/waitable_event.h"
+#include "base/threading/platform_thread.h"
+
+namespace blink::canvas_bridge {
+
+class CanvasBridgeClient : public base::PlatformThread::Delegate {
+ public:
+  // Lazily creates the singleton on first call; returns nullptr when the bridge
+  // is not configured (--canvas-bridge-url unset). The instance is leaked for
+  // the process lifetime (never destroyed).
+  static CanvasBridgeClient* Get();
+
+  CanvasBridgeClient(const CanvasBridgeClient&) = delete;
+  CanvasBridgeClient& operator=(const CanvasBridgeClient&) = delete;
+
+  bool Connected();
+
+  // Monotonic, renderer-local id for a server-side canvas surface.
+  uint32_t AllocateCanvasId();
+
+  // Sends an already-encoded message frame to the server (callable from any
+  // thread). Returns false if not connected.
+  bool Send(base::span<const uint8_t> frame);
+
+  // Blocking: sends a GetImageData request and waits up to 5s for the reply.
+  // Returns the RGBA8 pixel buffer (width*height*4) or nullopt on
+  // timeout/error, in which case the caller falls back to local rendering.
+  std::optional<std::vector<uint8_t>> RequestImageData(uint32_t canvas_id,
+                                                       int32_t x,
+                                                       int32_t y,
+                                                       uint32_t width,
+                                                       uint32_t height);
+
+  // Blocking: sends a MeasureText request and waits up to 5s; returns the 9
+  // metric doubles packed as bytes (or nullopt on timeout).
+  std::optional<std::vector<uint8_t>> RequestTextMetrics(
+      uint32_t canvas_id, const std::string& text);
+
+ private:
+  CanvasBridgeClient(std::string host,
+                     int port,
+                     std::string path,
+                     std::string auth);
+  ~CanvasBridgeClient() override;
+
+  // base::PlatformThread::Delegate: connect + handshake + read loop.
+  void ThreadMain() override;
+
+  bool Connect();
+  void ReadLoop();
+  void Dispatch(base::span<const uint8_t> frame);
+
+  bool WriteWebSocketFrame(base::span<const uint8_t> payload);
+  bool ReadWebSocketFrame(std::vector<uint8_t>* out);
+  bool ReadExact(void* buf, size_t n);
+  bool WriteExact(const void* buf, size_t n);
+  void CloseSocket();
+
+  const std::string host_;
+  const int port_;
+  const std::string path_;
+  const std::string auth_;
+
+  // Raw socket handle stored width-agnostically (POSIX int fd or Windows
+  // SOCKET both fit a uintptr_t; the invalid sentinel is (uintptr_t)-1).
+  uintptr_t socket_ = static_cast<uintptr_t>(-1);
+
+  base::Lock write_lock_;  // serializes socket writes across threads
+
+  base::Lock state_lock_;
+  bool connected_ = false;  // guarded by state_lock_
+
+  base::Lock id_lock_;
+  uint32_t next_canvas_id_ = 1;  // guarded by id_lock_
+
+  struct PendingReadback {
+    base::WaitableEvent event{base::WaitableEvent::ResetPolicy::MANUAL,
+                              base::WaitableEvent::InitialState::NOT_SIGNALED};
+    std::optional<std::vector<uint8_t>> pixels;
+  };
+  base::Lock pending_lock_;
+  std::map<uint32_t, PendingReadback*> pending_;  // keyed by canvas_id
+};
+
+}  // namespace blink::canvas_bridge
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
