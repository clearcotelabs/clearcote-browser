+constexpr uintptr_t kInvalidSocket = static_cast<uintptr_t>(-1);
+
+#if BUILDFLAG(IS_WIN)
+void EnsureWinsock() {
+  static const bool started = [] {
+    WSADATA data;
+    return ::WSAStartup(MAKEWORD(2, 2), &data) == 0;
+  }();
+  (void)started;
+}
+#endif
+
+void CloseSocketHandle(uintptr_t s) {
+  if (s == kInvalidSocket)
+    return;
+#if BUILDFLAG(IS_WIN)
+  ::closesocket(static_cast<SOCKET>(s));
+#else
+  ::close(static_cast<int>(s));
+#endif
+}
+
+// Parses "ws://host:port/path" (wss:// accepted but treated as plaintext for
+// now — tunnel via Tailscale/SSH). Returns false on a malformed URL.
+bool ParseUrl(const std::string& url,
+              std::string* host,
+              int* port,
+              std::string* path) {
+  std::string_view v(url);
+  if (v.substr(0, 6) == "wss://") {
+    v.remove_prefix(6);
+  } else if (v.substr(0, 5) == "ws://") {
+    v.remove_prefix(5);
+  } else {
+    return false;
+  }
+  size_t slash = v.find('/');
+  std::string_view authority = v.substr(0, slash);
+  *path = slash == std::string_view::npos ? "/" : std::string(v.substr(slash));
+  size_t colon = authority.find(':');
+  if (colon == std::string_view::npos) {
+    *host = std::string(authority);
+    *port = 80;
+  } else {
+    *host = std::string(authority.substr(0, colon));
+    int p = 0;
+    if (!base::StringToInt(authority.substr(colon + 1), &p) || p <= 0)
+      return false;
+    *port = p;
+  }
+  return !host->empty();
+}
+
+}  // namespace
