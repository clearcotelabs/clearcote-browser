+// Canvas bridge wire codec. Both bridge endpoints are clearcote builds, so the
+// wire format is a plain little-endian binary encoding (no cross-language
+// interop is required). Every message is one self-contained frame:
+//   [u32 type][fields...]
+// Strings and byte blobs are length-prefixed (u32). Decoders return
+// std::nullopt on any truncation or type mismatch.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
+#define THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
+
+#include <cstdint>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/containers/span.h"
+
+namespace blink::canvas_bridge {
+
+enum class MessageType : uint32_t {
+  kUnknown = 0,
+  kHello = 1,                 // client -> server
+  kWelcome = 2,               // server -> client
+  kCreateCanvas2D = 3,        // client -> server
+  kCanvas2DGetImageData = 4,  // client -> server (request)
+  kImageData = 5,             // server -> client (reply; also WebGL readPixels)
+  kCanvas2DOp = 6,            // client -> server (one recorded 2D draw op)
+  kMeasureText = 7,           // client -> server (request; reply reuses kImageData
+                              // with the 9 metric doubles packed into pixels)
+  kCreateWebGL = 8,           // client -> server (create a server WebGL context)
+  kWebGLOp = 9,               // client -> server (one recorded WebGL command)
+};
+
+// WebGL command ids — must match the server's webgl_op_to_js dispatcher. A
+// single generic op message carries object ids (ints), numeric params (floats),
+// a string (shader source / attrib name), and binary (bufferData).
+enum class WebGLOp : uint32_t {
+  kUnknown = 0,
+  kCreateBuffer = 1, kCreateShader = 2, kCreateProgram = 3, kCreateTexture = 4,
+  kCreateFramebuffer = 5, kCreateRenderbuffer = 6, kDeleteObject = 9,
+  kShaderSource = 10, kCompileShader = 11, kAttachShader = 12,
+  kBindAttribLocation = 13, kLinkProgram = 14, kUseProgram = 15,
+  kGetUniformLocation = 16,
+  kBindBuffer = 20, kBufferData = 21, kBufferDataSize = 22, kBufferSubData = 23,
+  kEnableVertexAttribArray = 30, kDisableVertexAttribArray = 31,
+  kVertexAttribPointer = 32,
+  kUniform1f = 40, kUniform2f = 41, kUniform3f = 42, kUniform4f = 43,
+  kUniform1i = 44, kUniformMatrix4fv = 50,
+  kBindTexture = 60, kTexImage2D = 61, kTexParameteri = 62, kActiveTexture = 63,
+  kGenerateMipmap = 64, kTexParameterf = 65, kTexSubImage2D = 66,
+  kBindFramebuffer = 70, kFramebufferTexture2D = 71, kBindRenderbuffer = 72,
+  kRenderbufferStorage = 73, kFramebufferRenderbuffer = 74,
+  kViewport = 80, kClearColor = 81, kClear = 82, kEnable = 83, kDisable = 84,
+  kBlendFunc = 85, kDepthFunc = 86, kPixelStorei = 87, kScissor = 88,
+  kDrawArrays = 90, kDrawElements = 91,
+};
+
+// Canvas2D operation ids — must match the server's dispatcher. A single generic
+// op message (string arg + float args) carries all of them.
+enum class Canvas2DOp : uint32_t {
+  kUnknown = 0,
+  // State stack / path.
+  kSave = 1,
+  kRestore = 2,
+  kBeginPath = 3,
+  kClosePath = 4,
+  kFill = 5,
+  kStroke = 6,
+  kClip = 7,
+  // Rects.
+  kFillRect = 10,
+  kStrokeRect = 11,
+  kClearRect = 12,
+  // Text (str_arg = text).
+  kFillText = 20,
+  kStrokeText = 21,
+  // Path building.
+  kMoveTo = 30,
+  kLineTo = 31,
+  kRect = 32,
+  kArc = 33,
+  kArcTo = 34,
+  kQuadraticCurveTo = 35,
+  kBezierCurveTo = 36,
+  kEllipse = 37,
+  // Transforms.
+  kSetTransform = 40,
+  kTransform = 41,
+  kTranslate = 42,
+  kRotate = 43,
+  kScale = 44,
+  kResetTransform = 45,
+  // State setters (str_arg = color/font/keyword where applicable).
+  kSetFillStyle = 50,
+  kSetStrokeStyle = 51,
+  kSetLineWidth = 52,
+  kSetFont = 53,
+  kSetTextAlign = 54,
+  kSetTextBaseline = 55,
+  kSetGlobalAlpha = 56,
+  kSetGlobalCompositeOperation = 57,
+  kSetLineCap = 58,
+  kSetLineJoin = 59,
+  kSetMiterLimit = 60,
+  kSetLineDashOffset = 61,
+  kSetShadowColor = 62,
+  kSetShadowBlur = 63,
+  kSetShadowOffsetX = 64,
+  kSetShadowOffsetY = 65,
+  kSetDirection = 66,
+  kSetTextRendering = 67,
+  kSetLetterSpacing = 68,
+  kSetWordSpacing = 69,
+  kSetImageSmoothingEnabled = 70,
+};
+
+struct HelloMessage {
+  uint32_t protocol_version = 1;
+  uint64_t persona_seed = 0;
+  std::string client_version;
+};
+
+struct WelcomeMessage {
+  uint32_t protocol_version = 0;
+  std::string server_version;
+  std::string os;
+  std::string gpu_vendor;
+  std::string gpu_renderer;
+};
+
+struct CreateCanvas2DMessage {
+  uint32_t canvas_id = 0;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  bool opaque = false;
+};
+
+struct Canvas2DOpMessage {
+  uint32_t canvas_id = 0;
+  uint32_t op = 0;            // Canvas2DOp
+  std::string str_arg;       // text / color / font / keyword (empty if unused)
+  std::vector<double> args;  // numeric arguments
+};
+
+struct MeasureTextMessage {
+  uint32_t canvas_id = 0;
+  std::string text;
+};
+
+struct CreateWebGLMessage {
+  uint32_t canvas_id = 0;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  uint32_t context_type = 1;  // 1 = webgl, 2 = webgl2
+};
+
+struct WebGLOpMessage {
+  uint32_t canvas_id = 0;
+  uint32_t op = 0;             // WebGLOp
+  std::vector<int32_t> ints;   // object ids + GLenum/GLint params
+  std::vector<double> floats;  // numeric params
+  std::string str;             // shader source / attrib name (empty if unused)
