 void Geolocation::QueryNextPosition() {
+  // clearcote: with --fingerprint-location set, deliver the fabricated position directly instead
+  // of waiting on the real device service (which may have no provider). Permission was already
+  // required to reach here; the position is static so it is reported once per request.
+  if (device::mojom::blink::GeopositionPtr fp_pos =
+          FabricatedMojoPositionIfRequested()) {
+    last_position_ = CreateGeoposition(*fp_pos);
+    GetExecutionContext()
+        ->GetTaskRunner(TaskType::kMiscPlatformAPI)
+        ->PostTask(FROM_HERE, blink::BindOnce(&Geolocation::PositionChanged,
+                                              WrapPersistent(this)));
+    return;
+  }
   geolocation_->QueryNextPosition(
       blink::BindOnce(&Geolocation::OnPositionUpdated, WrapPersistent(this)));
 }
