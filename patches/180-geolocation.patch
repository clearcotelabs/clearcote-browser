+// clearcote: when --fingerprint-location="lat,lng" is set, build that fabricated mojo position.
+device::mojom::blink::GeopositionPtr FabricatedMojoPositionIfRequested() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(switches::kFingerprintLocation))
+    return nullptr;
+  const std::string v = cmd->GetSwitchValueASCII(switches::kFingerprintLocation);
+  const size_t comma = v.find(',');
+  double lat = 0., lng = 0.;
+  if (comma == std::string::npos ||
+      !base::StringToDouble(v.substr(0, comma), &lat) ||
+      !base::StringToDouble(v.substr(comma + 1), &lng))
+    return nullptr;
+  auto pos = device::mojom::blink::Geoposition::New();
+  pos->latitude = lat;
+  pos->longitude = lng;
+  pos->accuracy = 100.0;
+  pos->altitude = -10001.0;
+  pos->altitude_accuracy = -1.0;
+  pos->heading = -1.0;
+  pos->speed = -1.0;
+  pos->timestamp = base::Time::Now();
+  return pos;
+}
