+// Copyright 2026 Lightweight-Fork Authors. All rights reserved.
+
+#include "content/browser/devtools/protocol/humanized_cursor_overlay_mac.h"
+
+#import <AppKit/AppKit.h>
+#import <QuartzCore/QuartzCore.h>
+
+// The cursor dot and the element highlight box are rendered as borderless,
+// click-through CHILD VIEWS of the web-content NSView — not separate windows.
+// That keeps them INSIDE the browser content (clipped to it, composited with
+// the page, never floating over the toolbar or other apps), positions them in
+// the view's own coordinate space (correct on any display / scale factor /
+// window position — no primary-screen math), and avoids stealing key-window
+// focus the way a child NSWindow did. No drop shadows (no "glow").
+
+// A click-through child view that paints a CALayer. Declared at global scope —
+// Objective-C class declarations may not appear inside a C++ namespace.
+@interface CFOverlayView : NSView
+@end
+
+@implementation CFOverlayView
+- (NSView*)hitTest:(NSPoint)point {
+  return nil;  // click-through: the page, not the overlay, gets the event.
+}
+- (BOOL)isFlipped {
+  return YES;  // top-left origin, matching web-content coordinates.
+}
+@end
+
+namespace content {
+namespace devtools {
+namespace {
+
+constexpr CGFloat kDiameter = 44.0;
+constexpr CGFloat kRadius = kDiameter / 2.0;
+
+CFOverlayView* g_cursor = nil;
+CFOverlayView* g_rect = nil;
+
+CFOverlayView* EnsureCursor() {
+  if (g_cursor) {
+    return g_cursor;
+  }
+  g_cursor = [[CFOverlayView alloc]
+      initWithFrame:NSMakeRect(0, 0, kDiameter, kDiameter)];
+  g_cursor.wantsLayer = YES;
+  CALayer* layer = g_cursor.layer;
+  layer.backgroundColor =
+      [[NSColor colorWithRed:1.0 green:0.15 blue:0.15 alpha:0.80] CGColor];
+  layer.cornerRadius = kRadius;
+  layer.borderWidth = 1.5;
+  layer.borderColor = [[NSColor whiteColor] CGColor];
+  layer.masksToBounds = YES;  // no shadow / glow.
+  return g_cursor;
+}
+
+CFOverlayView* EnsureRect() {
+  if (g_rect) {
+    return g_rect;
+  }
+  g_rect = [[CFOverlayView alloc] initWithFrame:NSMakeRect(0, 0, 10, 10)];
+  g_rect.wantsLayer = YES;
+  CALayer* layer = g_rect.layer;
+  // Clean cyan outline, no fill wash and no shadow.
+  layer.backgroundColor = [[NSColor clearColor] CGColor];
+  layer.borderColor =
+      [[NSColor colorWithRed:0.0 green:0.82 blue:1.0 alpha:0.95] CGColor];
+  layer.borderWidth = 2.0;
+  layer.cornerRadius = 3.0;
+  layer.masksToBounds = YES;
+  return g_rect;
+}
+
+// Converts a top-left (y-down) y into the parent view's frame coordinate space.
+CGFloat OriginY(NSView* parent, CGFloat top_left_y, CGFloat height) {
+  if ([parent isFlipped]) {
+    return top_left_y;
+  }
+  return [parent bounds].size.height - top_left_y - height;
+}
+
+// (Re)attaches `overlay` as the frontmost child of `parent`.
+void AttachFrontmost(NSView* parent, NSView* overlay) {
+  if ([overlay superview]) {
+    [overlay removeFromSuperview];
+  }
+  [parent addSubview:overlay positioned:NSWindowAbove relativeTo:nil];
+}
+
+}  // namespace
+
+void ShowRectOverlay(gfx::NativeView parent_view,
+                     int x,
+                     int y,
+                     int width,
+                     int height) {
+  width = width < 2 ? 2 : width;
+  height = height < 2 ? 2 : height;
+  NSView* parent = parent_view.GetNativeNSView();
+  if (!parent) {
+    return;
+  }
+  CFOverlayView* v = EnsureRect();
+  // (x, y, w, h) is in the content view's own coordinate space (CSS/DIP,
+  // top-left). A subview frame lives in the parent's coordinate space.
+  v.frame = NSMakeRect(x, OriginY(parent, y, height), width, height);
+  AttachFrontmost(parent, v);
+}
+
+void HideRectOverlay() {
+  if (g_rect) {
+    [g_rect removeFromSuperview];
+  }
+}
+
+void ShowCursorOverlay(gfx::NativeView parent_view, int view_x, int view_y) {
+  NSView* parent = parent_view.GetNativeNSView();
+  if (!parent) {
+    return;
+  }
+  CFOverlayView* v = EnsureCursor();
+  const CGFloat tlx = view_x - kRadius;
+  const CGFloat tly = view_y - kRadius;
+  v.frame = NSMakeRect(tlx, OriginY(parent, tly, kDiameter), kDiameter, kDiameter);
+  AttachFrontmost(parent, v);
+}
+
+void UpdateCursorOverlay(int view_x, int view_y) {
+  if (!g_cursor) {
+    return;
+  }
+  NSView* parent = [g_cursor superview];
+  if (!parent) {
+    return;
+  }
+  const CGFloat tlx = view_x - kRadius;
+  const CGFloat tly = view_y - kRadius;
+  g_cursor.frame =
+      NSMakeRect(tlx, OriginY(parent, tly, kDiameter), kDiameter, kDiameter);
+}
+
+void HideCursorOverlay() {
+  if (g_cursor) {
+    [g_cursor removeFromSuperview];
+  }
+}
+
