+  // clearcote: keep the WebGPU adapter identity coherent with the spoofed WebGL
+  // GPU. An explicit --fingerprint-webgpu-* switch wins; otherwise fall back to
+  // the seed-/profile-derived persona (CurrentPersona), so a seed-only persona is
+  // coherent too and navigator.gpu can't contradict the WebGL UNMASKED vendor.
+  {
+    const base::CommandLine* cc_cmd = base::CommandLine::ForCurrentProcess();
+    const auto& cc_persona = ungoogled::CurrentPersona();
+    if (cc_cmd->HasSwitch("fingerprint-webgpu-vendor")) {
+      vendor_ = String::FromUtf8(
+          cc_cmd->GetSwitchValueASCII("fingerprint-webgpu-vendor"));
+    } else if (!cc_persona.webgpu_vendor.empty()) {
+      vendor_ = String::FromUtf8(cc_persona.webgpu_vendor);
+    }
+    if (cc_cmd->HasSwitch("fingerprint-webgpu-architecture")) {
+      architecture_ = String::FromUtf8(
+          cc_cmd->GetSwitchValueASCII("fingerprint-webgpu-architecture"));
+    } else if (!cc_persona.webgpu_architecture.empty()) {
+      architecture_ = String::FromUtf8(cc_persona.webgpu_architecture);
+    }
+    if (cc_cmd->HasSwitch("fingerprint-webgpu-device")) {
+      device_ = String::FromUtf8(
+          cc_cmd->GetSwitchValueASCII("fingerprint-webgpu-device"));
+    }
+    if (cc_cmd->HasSwitch("fingerprint-webgpu-description")) {
+      description_ = String::FromUtf8(
+          cc_cmd->GetSwitchValueASCII("fingerprint-webgpu-description"));
+    }
+  }
