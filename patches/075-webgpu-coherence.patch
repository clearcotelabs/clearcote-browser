+  // clearcote: override the reported WebGPU adapter limits with the persona
+  // table so they stay coherent with the spoofed WebGL GPU and don't leak the
+  // host GPU's real capabilities (an integrated/software backend under a
+  // spoofed discrete GPU). Keys absent from the table keep the real value; the
+  // uint64_t source covers both the 32- and 64-bit limit fields. Mirrors the
+  // always-on WebGL getParameter spoof (an imported profile can override).
+  {
+    const auto& cc_pl = ungoogled::CurrentPersona().webgpu_limits;
+#define CC_WGPU_SET(field)                                               \
+  do {                                                                   \
+    auto cc_it = cc_pl.find(#field);                                     \
+    if (cc_it != cc_pl.end())                                            \
+      limits.field = static_cast<decltype(limits.field)>(cc_it->second); \
+  } while (0)
+    CC_WGPU_SET(maxTextureDimension1D);
+    CC_WGPU_SET(maxTextureDimension2D);
+    CC_WGPU_SET(maxTextureDimension3D);
+    CC_WGPU_SET(maxTextureArrayLayers);
+    CC_WGPU_SET(maxBindGroups);
+    CC_WGPU_SET(maxBindGroupsPlusVertexBuffers);
+    CC_WGPU_SET(maxBindingsPerBindGroup);
+    CC_WGPU_SET(maxDynamicUniformBuffersPerPipelineLayout);
+    CC_WGPU_SET(maxDynamicStorageBuffersPerPipelineLayout);
+    CC_WGPU_SET(maxSampledTexturesPerShaderStage);
+    CC_WGPU_SET(maxSamplersPerShaderStage);
+    CC_WGPU_SET(maxStorageBuffersPerShaderStage);
+    CC_WGPU_SET(maxStorageTexturesPerShaderStage);
+    CC_WGPU_SET(maxUniformBuffersPerShaderStage);
+    CC_WGPU_SET(maxUniformBufferBindingSize);
+    CC_WGPU_SET(maxStorageBufferBindingSize);
+    CC_WGPU_SET(minUniformBufferOffsetAlignment);
+    CC_WGPU_SET(minStorageBufferOffsetAlignment);
+    CC_WGPU_SET(maxVertexBuffers);
+    CC_WGPU_SET(maxBufferSize);
+    CC_WGPU_SET(maxVertexAttributes);
+    CC_WGPU_SET(maxVertexBufferArrayStride);
+    CC_WGPU_SET(maxInterStageShaderVariables);
+    CC_WGPU_SET(maxColorAttachments);
+    CC_WGPU_SET(maxColorAttachmentBytesPerSample);
+    CC_WGPU_SET(maxComputeWorkgroupStorageSize);
+    CC_WGPU_SET(maxComputeInvocationsPerWorkgroup);
+    CC_WGPU_SET(maxComputeWorkgroupSizeX);
+    CC_WGPU_SET(maxComputeWorkgroupSizeY);
+    CC_WGPU_SET(maxComputeWorkgroupSizeZ);
+    CC_WGPU_SET(maxComputeWorkgroupsPerDimension);
+    CC_WGPU_SET(maxStorageBuffersInFragmentStage);
+    CC_WGPU_SET(maxStorageTexturesInFragmentStage);
+    CC_WGPU_SET(maxStorageBuffersInVertexStage);
+    CC_WGPU_SET(maxStorageTexturesInVertexStage);
+#undef CC_WGPU_SET
+  }
